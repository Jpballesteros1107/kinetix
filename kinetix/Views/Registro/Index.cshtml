@model kinetix.Models.Usuario

@{
    ViewBag.Title = "Registro";
}

<style>

    body {
        background: #000;
        min-height: 100vh;
        color: #fff;
    }

    .register-wrapper {
        min-height: 100vh;
        display: flex;
        align-items: center;
    }

    .register-card {
        background: rgba(20,20,20,.95);
        border: 1px solid rgba(255,255,255,.08);
        border-radius: 30px;
        overflow: hidden;
        box-shadow: 0 25px 60px rgba(0,0,0,.6);
        backdrop-filter: blur(15px);
    }

    .register-left {
        background: linear-gradient( 135deg, #000000 0%, #0f0f0f 50%, #181818 100% );
        color: white;
        padding: 70px;
        position: relative;
    }

        .register-left::before {
            content: "";
            position: absolute;
            width: 300px;
            height: 300px;
            background: #00c853;
            filter: blur(150px);
            opacity: .15;
            top: -80px;
            left: -80px;
        }

        .register-left h1 {
            font-size: 58px;
            font-weight: 900;
            line-height: 1;
            margin-bottom: 25px;
        }

        .register-left p {
            color: rgba(255,255,255,.75);
            font-size: 17px;
        }

    .feature-item {
        margin-top: 25px;
        font-size: 16px;
        display: flex;
        align-items: center;
    }

        .feature-item i {
            color: #00e676;
            margin-right: 12px;
            font-size: 22px;
        }

    .register-right {
        background: #111;
        padding: 60px;
    }

    .form-title {
        font-size: 34px;
        font-weight: 800;
        color: white;
    }

    .form-subtitle {
        color: #9e9e9e;
        margin-bottom: 35px;
    }

    .form-label {
        color: #fff;
        font-weight: 600;
    }

    .form-control {
        background: #1b1b1b;
        border: 1px solid #2f2f2f;
        color: white;
        border-radius: 14px;
        height: 58px;
        padding-left: 18px;
        transition: .3s;
    }

        .form-control::placeholder {
            color: #777;
        }

        .form-control:focus {
            background: #222;
            color: white;
            border-color: #00c853;
            box-shadow: 0 0 0 4px rgba(0,200,83,.15);
        }

    .btn-register {
        height: 58px;
        border: none;
        border-radius: 14px;
        background: #00c853;
        color: white;
        font-weight: 700;
        font-size: 16px;
        transition: .3s;
    }

        .btn-register:hover {
            background: #00e676;
            transform: translateY(-3px);
            box-shadow: 0 10px 25px rgba(0,230,118,.35);
        }

    .login-link {
        color: #00e676;
        text-decoration: none;
        font-weight: 700;
    }

        .login-link:hover {
            color: white;
        }

    .alert-danger {
        background: #2a1010;
        border: 1px solid #842029;
        color: #ffb3b3;
    }

    @@media(max-width:991px) {

        .register-left {
            display: none;
        }

        .register-right {
            padding: 35px;
        }

        .register-card {
            border-radius: 20px;
        }
    
    }
</style>

<div class="container register-wrapper">

    <div class="row justify-content-center w-100">

        <div class="col-xl-10">

            <div class="card register-card">

                <div class="row g-0">

                    <!-- LADO IZQUIERDO -->
                    <div class="col-lg-6">

                        <div class="register-left d-flex flex-column justify-content-center">

                            <h1>
                                Únete a
                                Kinetix
                            </h1>

                            <p>

                                La nueva experiencia de movilidad
                                urbana rápida, moderna y segura.

                            </p>

                            <div class="feature-item">

                                <i class="bi bi-check-circle-fill"></i>

                                Viajes seguros y monitoreados

                            </div>

                            <div class="feature-item">

                                <i class="bi bi-check-circle-fill"></i>

                                Conductores verificados

                            </div>

                            <div class="feature-item">

                                <i class="bi bi-check-circle-fill"></i>

                                Facturación y seguimiento en tiempo real

                            </div>

                            <div class="mt-5 text-center">
                                <i class="bi bi-car-front-fill"
                                   style="font-size:120px;color:#00e676;">
                                </i>
                            </div>

                        </div>

                    </div>


                    <!-- LADO DERECHO -->
                    <div class="col-lg-6">

                        <div class="register-right">

                            <h2 class="form-title">

                                Crear Cuenta

                            </h2>

                            <p class="form-subtitle">

                                Completa tus datos para comenzar.

                            </p>

                            @if (ViewBag.Error != null)
                            {
                                <div class="alert alert-danger rounded-4">

                                    @ViewBag.Error

                                </div>
                            }

                            @using (Html.BeginForm())
                            {
                                <div class="mb-4">

                                    <label class="form-label">

                                        Nombre Completo

                                    </label>

                                    @Html.TextBoxFor(
                                        x => x.Nombre,
                                        new
                                        {
                                            @class = "form-control",
                                            placeholder = "Ingresa tu nombre"
                                        })

                                </div>

                                <div class="mb-4">

                                    <label class="form-label">

                                        Correo Electrónico

                                    </label>

                                    @Html.TextBoxFor(
                                        x => x.Correo,
                                        new
                                        {
                                            @class = "form-control",
                                            placeholder = "correo@ejemplo.com"
                                        })

                                </div>

                                <div class="mb-4">

                                    <label class="form-label">

                                        Teléfono

                                    </label>

                                    @Html.TextBoxFor(
                                        x => x.Telefono,
                                        new
                                        {
                                            @class = "form-control",
                                            placeholder = "3001234567"
                                        })

                                </div>

                                <div class="mb-4">

                                    <label class="form-label">

                                        Contraseña

                                    </label>

                                    @Html.PasswordFor(
                                        x => x.Password,
                                        new
                                        {
                                            @class = "form-control",
                                            placeholder = "********"
                                        })

                                </div>

                                <button class="btn btn-register w-100">
                                    <i class="bi bi-person-plus-fill me-2"></i>
                                    Crear Cuenta
                                </button>

                                <div class="text-center mt-4">

                                    ¿Ya tienes cuenta?

                                    <a href="/Login"
                                       class="login-link">

                                        Inicia sesión

                                    </a>

                                </div>
                            }

                        </div>

                    </div>

                </div>

            </div>

        </div>

    </div>

</div>
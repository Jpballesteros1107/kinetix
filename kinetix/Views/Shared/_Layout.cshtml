<!DOCTYPE html>
<html>
<head>

    <meta charset="utf-8" />

    <meta name="viewport"
          content="width=device-width, initial-scale=1.0">

    <title>
        @ViewBag.Title - Kinetix
    </title>

    @Styles.Render("~/Content/css")

    @Scripts.Render("~/bundles/modernizr")

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css"
          rel="stylesheet">

    <link rel="preconnect"
          href="https://fonts.googleapis.com">

    <link rel="preconnect"
          href="https://fonts.gstatic.com"
          crossorigin>

    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap"
          rel="stylesheet">

    <style>

        body {
            background: #f8f9fa;
            font-family: 'Inter', sans-serif;
            color: #1f1f1f;
        }

        /* =========================
           NAVBAR
        ==========================*/

        .navbar {
            background: #000 !important;
            padding-top: 14px;
            padding-bottom: 14px;
            box-shadow: 0 4px 15px rgba(0,0,0,0.1);
        }

        .navbar-brand {
            font-size: 28px;
            font-weight: 700;
            letter-spacing: 1px;
            color: white !important;
        }

        .nav-link {
            color: rgba(255,255,255,0.85) !important;
            font-weight: 500;
            margin-right: 10px;
            transition: 0.3s;
        }

            .nav-link:hover {
                color: #00c853 !important;
            }

        /* =========================
           BOTONES
        ==========================*/

        .btn-kinetix {
            background: #00c853;
            border: none;
            color: white;
            padding: 10px 22px;
            border-radius: 12px;
            font-weight: 600;
            transition: 0.3s;
        }

            .btn-kinetix:hover {
                background: #00b248;
                color: white;
                transform: translateY(-2px);
            }

        .btn-dark-custom {
            background: #111;
            color: white;
            border-radius: 12px;
            padding: 10px 22px;
            font-weight: 600;
        }

            .btn-dark-custom:hover {
                background: #222;
                color: white;
            }

        /* =========================
           CONTENIDO
        ==========================*/

        .body-content {
            min-height: 80vh;
            padding-top: 40px;
            padding-bottom: 40px;
        }

        /* =========================
           FOOTER
        ==========================*/

        footer {
            background: #000;
            color: rgba(255,255,255,0.7);
            padding: 30px 0;
            margin-top: 60px;
            text-align: center;
        }

            footer h5 {
                color: white;
                margin-bottom: 10px;
            }

        /* =========================
           BADGES
        ==========================*/

        .user-badge {
            background: rgba(255,255,255,0.12);
            padding: 8px 14px;
            border-radius: 20px;
            color: white;
            font-size: 14px;
        }
    </style>

</head>

<body>

    <!-- NAVBAR -->
    <nav class="navbar navbar-expand-lg navbar-dark">

        <div class="container">

            <a class="navbar-brand"
               href="/">

                KINETIX

            </a>

            <button class="navbar-toggler"
                    type="button"
                    data-bs-toggle="collapse"
                    data-bs-target="#menu">

                <span class="navbar-toggler-icon"></span>

            </button>

            <div class="collapse navbar-collapse"
                 id="menu">

                <!-- MENU IZQUIERDA -->
                <ul class="navbar-nav me-auto">

                    <li class="nav-item">

                        <a class="nav-link"
                           href="/Home">

                            Inicio

                        </a>

                    </li>

                    @if (Session["Rol"] != null
                      && Session["Rol"].ToString() == "Admin")
                    {
                        <li class="nav-item">

                            <a class="nav-link"
                               href="/Usuario">

                                Usuarios

                            </a>

                        </li>

                        <li class="nav-item">

                            <a class="nav-link"
                               href="/Conductor">

                                Conductores

                            </a>

                        </li>

                        <li class="nav-item">

                            <a class="nav-link"
                               href="/Vehiculo">

                                Vehículos

                            </a>

                        </li>

                        <li class="nav-item">

                            <a class="nav-link"
                               href="/Pedido">

                                Viajes

                            </a>

                        </li>

                        <li class="nav-item">

                            <a class="nav-link"
                               href="/Factura">

                                Facturas

                            </a>

                        </li>
                    }

                    @if (Session["Rol"] != null
                      && Session["Rol"].ToString() == "Cliente")
                    {
                        <li class="nav-item">

                            <a class="nav-link"
                               href="/Pedido/Create">

                                Solicitar Viaje

                            </a>

                        </li>

                        <li class="nav-item">

                            <a class="nav-link"
                               href="/Factura">

                                Mis Facturas

                            </a>

                        </li>
                    }

                    @if (Session["Rol"] != null
                      && Session["Rol"].ToString() == "Conductor")
                    {
                        <li class="nav-item">

                            <a class="nav-link"
                               href="/Pedido">

                                Viajes Disponibles

                            </a>

                        </li>
                    }

                </ul>


                <!-- MENU DERECHA -->
                <ul class="navbar-nav align-items-center">

                    @if (Session["Usuario"] == null)
                    {
                        <li class="nav-item me-2">

                            <a class="nav-link"
                               href="/Login">

                                Iniciar Sesión

                            </a>

                        </li>

                        <li class="nav-item me-2">

                            <a class="btn btn-light rounded-pill px-4"
                               href="/Registro">

                                Registro

                            </a>

                        </li>

                        <li class="nav-item">

                            <a class="btn btn-kinetix"
                               href="/ConductorRegistro">

                                Conducir con Kinetix

                            </a>

                        </li>
                    }
                    else
                    {
                        <li class="nav-item me-3">

                            <span class="user-badge">

                                Hola @Session["Usuario"]

                            </span>

                        </li>

                        <li class="nav-item">

                            <a class="btn btn-outline-light rounded-pill px-4"
                               href="/Login/Logout">

                                Cerrar Sesión

                            </a>

                        </li>
                    }

                </ul>

            </div>

        </div>

    </nav>


    <!-- CONTENIDO -->
    <main class="container body-content">

        @RenderBody()

    </main>


    <!-- FOOTER -->
    <footer>

        <div class="container">

            <h5>
                KINETIX
            </h5>

            <p>

                Plataforma inteligente de movilidad urbana.

            </p>

            <small>

                © @DateTime.Now.Year Kinetix.
                Todos los derechos reservados.

            </small>

        </div>

    </footer>


    @Scripts.Render("~/bundles/jquery")

    @Scripts.Render("~/bundles/bootstrap")

    @RenderSection("scripts", required: false)

</body>

</html>
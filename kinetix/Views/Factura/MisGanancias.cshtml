@model List<kinetix.Models.Factura>

@{
    ViewBag.Title = "Mis Ganancias";
    Layout = "~/Views/Shared/_LayoutConductor.cshtml";
}

<div class="container">

    <h2 class="mb-4">
        Mis Ganancias
    </h2>

    <table class="table table-hover">

        <thead class="table-dark">

            <tr>
                <th>Factura</th>
                <th>Cliente</th>
                <th>Fecha</th>
                <th>Total</th>
                <th>Estado</th>
            </tr>

        </thead>

        <tbody>

            @foreach (var item in Model)
            {
                <tr>

                    <td>
                        #@item.IdFactura
                    </td>

                    <td>
                        @item.Cliente
                    </td>

                    <td>
                        @item.Fecha.ToString("dd/MM/yyyy")
                    </td>

                    <td>
                        $@String.Format("{0:N0}", item.Total)
                    </td>

                    <td>

                        <span class="badge bg-success">

                            @item.Estado

                        </span>

                    </td>

                </tr>
            }

        </tbody>

        <div class="alert alert-success mb-4">

            <h4>

                Total Ganado:
                $@String.Format("{0:N0}", ViewBag.TotalGanado)

            </h4>

        </div>

    </table>

</div>
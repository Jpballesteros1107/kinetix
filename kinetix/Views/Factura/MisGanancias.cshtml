@model List<kinetix.Models.Factura>

@{
    ViewBag.Title = "Mis Ganancias";
    Layout = "~/Views/Shared/_LayoutConductor.cshtml";
}

<div class="container py-4">

    <!-- ENCABEZADO -->
    <div class="d-flex justify-content-between align-items-center flex-wrap mb-4">

        <div>
            <h2 class="fw-bold mb-1">
                <i class="bi bi-cash-coin me-2 text-success"></i>
                Mis Ganancias
            </h2>

            <p class="text-muted mb-0">
                Historial de ingresos generados por tus viajes.
            </p>
        </div>

        <div class="card border-0 shadow-sm mt-3 mt-md-0"
             style="background:linear-gradient(135deg,#00c853,#00e676);
                    color:white;
                    border-radius:20px;">

            <div class="card-body text-center px-4 py-3">

                <small class="d-block">
                    Total Ganado
                </small>

                <h3 class="fw-bold mb-0">
                    $@String.Format("{0:N0}", ViewBag.TotalGanado ?? 0)
                </h3>

            </div>

        </div>

    </div>

    <!-- SI NO HAY FACTURAS -->
    @if (Model == null || !Model.Any())
    {
        <div class="alert alert-warning shadow-sm">

            <i class="bi bi-exclamation-circle me-2"></i>

            Aún no tienes ganancias registradas.

        </div>
    }
    else
    {
        <div class="card border-0 shadow-lg">

            <div class="card-body p-0">

                <div class="table-responsive">

                    <table class="table table-hover align-middle mb-0">

                        <thead class="table-dark">

                            <tr>
                                <th>Factura</th>
                                <th>Cliente</th>
                                <th>Fecha</th>
                                <th>Total</th>
                                <th>Estado</th>
                            </tr>

                        </thead>

                        <tbody>

                            @foreach (var item in Model)
                            {
                                <tr>

                                    <td>
                                        <strong>
                                            #@item.IdFactura
                                        </strong>
                                    </td>

                                    <td>
                                        @item.Cliente
                                    </td>

                                    <td>
                                        @item.Fecha.ToString("dd/MM/yyyy")
                                    </td>

                                    <td class="fw-bold text-success">
                                        $@String.Format("{0:N0}", item.Total)
                                    </td>

                                    <td>

                                        @if (item.Estado == "Pagada")
                                        {
                                            <span class="badge bg-success">
                                                @item.Estado
                                            </span>
                                        }
                                        else if (item.Estado == "Pendiente")
                                        {
                                            <span class="badge bg-warning text-dark">
                                                @item.Estado
                                            </span>
                                        }
                                        else
                                        {
                                            <span class="badge bg-secondary">
                                                @item.Estado
                                            </span>
                                        }

                                    </td>

                                </tr>
                            }

                        </tbody>

                    </table>

                </div>

            </div>

        </div>
    }

</div>
@model List<kinetix.Models.Factura>

@{
    ViewBag.Title = "Mis Facturas";
    Layout = "~/Views/Shared/_LayoutCliente.cshtml";
}

<div class="container mt-4">

    <div class="d-flex justify-content-between align-items-center mb-4">

        <div>
            <h2 class="fw-bold">
                Mis Facturas
            </h2>

            <p class="text-muted">
                Historial de pagos realizados
            </p>
        </div>

    </div>

    <div class="alert alert-primary">

        <h5 class="mb-0">

            Total Pagado:
            $@String.Format("{0:N0}", ViewBag.TotalPagado)

        </h5>

    </div>

    <div class="card shadow border-0">

        <div class="card-body">

            <div class="table-responsive">

                <table class="table table-hover">

                    <thead class="table-dark">

                        <tr>
                            <th>Factura</th>
                            <th>Pedido</th>
                            <th>Fecha</th>
                            <th>Total</th>
                            <th>Método</th>
                            <th>Estado</th>
                        </tr>

                    </thead>

                    <tbody>

                        @foreach (var item in Model)
                        {
                            <tr>

                                <td>
                                    #@item.IdFactura
                                </td>

                                <td>
                                    #@item.IdPedido
                                </td>

                                <td>
                                    @item.Fecha.ToString("dd/MM/yyyy")
                                </td>

                                <td>
                                    <strong>
                                        $@String.Format("{0:N0}", item.Total)
                                    </strong>
                                </td>

                                <td>
                                    @item.MetodoPago
                                </td>

                                <td>

                                    <span class="badge bg-success">

                                        @item.Estado

                                    </span>

                                </td>

                            </tr>
                        }

                    </tbody>

                </table>

            </div>

        </div>

    </div>

</div>
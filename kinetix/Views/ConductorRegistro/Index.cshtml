@model kinetix.Models.SolicitudConductor

@{
    ViewBag.Title = "Conducir con Kinetix";
}

<style>

    body {
        background: radial-gradient(circle at top, rgba(0,200,83,0.10), transparent 35%), #0b0b0b;
        overflow-x: hidden;
    }

    .driver-page {
        min-height: 100vh;
        display: flex;
        align-items: center;
        justify-content: center;
        padding: 50px 20px;
        position: relative;
    }

    .driver-glow {
        position: absolute;
        width: 500px;
        height: 500px;
        background: #00c853;
        border-radius: 50%;
        filter: blur(180px);
        opacity: 0.08;
        top: -120px;
        left: -120px;
    }

    .driver-container {
        width: 100%;
        max-width: 1200px;
        background: #141414;
        border-radius: 32px;
        overflow: hidden;
        border: 1px solid rgba(255,255,255,0.06);
        box-shadow: 0 30px 80px rgba(0,0,0,0.45);
        position: relative;
        z-index: 2;
    }

    .driver-left {
        background: linear-gradient( 135deg, #000, #111, #1a1a1a );
        color: white;
        padding: 70px;
        position: relative;
        overflow: hidden;
        height: 100%;
    }

        .driver-left::before {
            content: '';
            position: absolute;
            width: 450px;
            height: 450px;
            background: rgba(0,200,83,0.08);
            border-radius: 50%;
            bottom: -180px;
            right: -140px;
        }

    .brand {
        display: flex;
        align-items: center;
        gap: 12px;
        margin-bottom: 60px;
        position: relative;
        z-index: 2;
    }

    .brand-icon {
        width: 42px;
        height: 42px;
        background: #00c853;
        border-radius: 14px;
        display: flex;
        align-items: center;
        justify-content: center;
        font-weight: 900;
        font-size: 18px;
    }

    .brand-name {
        font-size: 24px;
        font-weight: 800;
        letter-spacing: 1px;
    }

    .hero-title {
        font-size: 56px;
        font-weight: 900;
        line-height: 1.05;
        margin-bottom: 24px;
        position: relative;
        z-index: 2;
    }

    .hero-text {
        color: rgba(255,255,255,0.7);
        font-size: 18px;
        line-height: 1.8;
        max-width: 500px;
        position: relative;
        z-index: 2;
    }

    .hero-features {
        margin-top: 45px;
        position: relative;
        z-index: 2;
    }

    .feature-item {
        display: flex;
        align-items: center;
        margin-bottom: 18px;
        color: rgba(255,255,255,0.85);
        font-weight: 500;
    }

        .feature-item i {
            color: #00c853;
            margin-right: 14px;
            font-size: 20px;
        }

    .hero-icon {
        position: absolute;
        right: 40px;
        bottom: 20px;
        font-size: 130px;
        color: rgba(255,255,255,0.05);
    }

    .driver-right {
        background: #141414;
        padding: 70px 60px;
        color: white;
    }

    .form-title {
        font-size: 38px;
        font-weight: 800;
        margin-bottom: 10px;
    }

    .form-subtitle {
        color: rgba(255,255,255,0.45);
        margin-bottom: 40px;
        font-size: 15px;
    }

    .form-label-custom {
        font-size: 14px;
        font-weight: 600;
        color: rgba(255,255,255,0.8);
        margin-bottom: 10px;
        display: block;
    }

    .input-wrap {
        position: relative;
        margin-bottom: 22px;
    }

    .input-icon {
        position: absolute;
        left: 18px;
        top: 50%;
        transform: translateY(-50%);
        color: rgba(255,255,255,0.3);
        font-size: 16px;
    }

    .input-custom {
        width: 100%;
        height: 58px;
        border-radius: 16px;
        border: 1px solid rgba(255,255,255,0.08);
        background: #1d1d1d;
        padding-left: 50px;
        padding-right: 18px;
        color: white;
        font-size: 15px;
        outline: none;
        transition: 0.25s;
    }

        .input-custom::placeholder {
            color: rgba(255,255,255,0.2);
        }

        .input-custom:focus {
            border-color: #00c853;
            box-shadow: 0 0 0 4px rgba(0,200,83,0.12);
        }

    .btn-driver {
        width: 100%;
        height: 58px;
        border: none;
        border-radius: 16px;
        background: #00c853;
        color: white;
        font-size: 16px;
        font-weight: 700;
        transition: 0.25s;
        margin-top: 10px;
    }

        .btn-driver:hover {
            background: #00b248;
            transform: translateY(-2px);
        }

    .alert-custom {
        background: rgba(25,135,84,0.12);
        border: 1px solid rgba(25,135,84,0.35);
        color: #5dff9b;
        border-radius: 14px;
        padding: 14px 18px;
        margin-bottom: 28px;
        font-size: 14px;
    }

    @@media(max-width:991px) 
    {

        .driver-left {
            display: none;
        }

        .driver-right {
            padding: 45px 30px;
        }

        .form-title {
            font-size: 30px;
        }
    }

    .driver-container{
        animation: fadeUp .7s ease;
        backdrop-filter: blur(16px);
    }

    .driver-right{
        background: linear-gradient(
            180deg,
            #141414,
            #101010
        );
    }

    .input-custom{
        height:60px;
        border-radius:18px;
        transition:.25s;
    }

    .input-custom:hover{
        border-color:rgba(0,200,83,.4);
    }

    .input-custom:focus{
        background:#222;
        border-color:#00e676;
        box-shadow:0 0 0 5px rgba(0,230,118,.12);
    }

    .btn-driver{
        background:linear-gradient(
            135deg,
            #00c853,
            #00e676
        );
        font-weight:800;
        letter-spacing:.4px;
    }

    .btn-driver:hover{
        box-shadow:0 15px 35px rgba(0,230,118,.25);
    }

        @@keyframes fadeUp{

                        from{
                            opacity:0;
                            transform:translateY(25px);
                        }

                        to{
                            opacity:1;
                            transform:translateY(0);
                        }
        }

</style>


<div class="driver-page">

    <div class="driver-glow"></div>

    <div class="driver-container">

        <div class="row g-0">

            <!-- LEFT -->
            <div class="col-lg-6">

                <div class="driver-left">

                    <div class="brand">

                        <div class="brand-icon">
                            K
                        </div>

                        <div class="brand-name">
                            KINETIX
                        </div>

                    </div>

                    <h1 class="hero-title">

                        Genera ingresos
                        conduciendo
                        con Kinetix.

                    </h1>

                    <p class="hero-text">

                        Únete a nuestra plataforma y comienza
                        a recibir solicitudes de viaje cerca
                        de tu ubicación de manera rápida y segura.

                    </p>

                    <div class="hero-features">

                        <div class="feature-item">

                            <i class="bi bi-check-circle-fill"></i>

                            Horarios flexibles

                        </div>

                        <div class="feature-item">

                            <i class="bi bi-check-circle-fill"></i>

                            Más viajes cerca de ti

                        </div>

                        <div class="feature-item">

                            <i class="bi bi-check-circle-fill"></i>

                            Plataforma moderna y segura

                        </div>

                    </div>

                    <i class="bi bi-car-front-fill hero-icon"></i>

                </div>

            </div>


            <!-- RIGHT -->
            <div class="col-lg-6">

                <div class="driver-right">

                    <h2 class="form-title">

                        Solicitud de conductor

                    </h2>

                    <p class="form-subtitle">

                        Completa tus datos y nuestro equipo
                        revisará tu solicitud.

                    </p>

                    @if (ViewBag.Mensaje != null)
                    {
                        <div class="alert-custom">


                            <i class="bi bi-check-circle me-2"></i>

                            @ViewBag.Mensaje

                        </div>

                    }

                    @using (Html.BeginForm())
                    {
                        <div class="row">

                            <!-- NOMBRE -->
                            <div class="col-12">

                                <label class="form-label-custom">
                                    Nombre completo
                                </label>

                                <div class="input-wrap">

                                    <i class="bi bi-person input-icon"></i>

                                    @Html.TextBoxFor(
                                        m => m.Nombre,
                                        new
                                        {
                                            @class = "input-custom",
                                            placeholder = "Juan Pablo"
                                        })

                                </div>

                            </div>

                            <!-- CORREO -->
                            <div class="col-12">

                                <label class="form-label-custom">
                                    Correo electrónico
                                </label>

                                <div class="input-wrap">

                                    <i class="bi bi-envelope input-icon"></i>

                                    @Html.TextBoxFor(
                                        m => m.Correo,
                                        new
                                        {
                                            @class = "input-custom",
                                            placeholder = "correo@ejemplo.com"
                                        }
                                        )

                                </div>

                            </div>

                            <!-- TELEFONO -->
                            <div class="col-md-6">

                                <label class="form-label-custom">
                                    Teléfono
                                </label>

                                <div class="input-wrap">

                                    <i class="bi bi-telephone input-icon"></i>

                                    @Html.TextBoxFor(
                                        m => m.Telefono,
                                        new
                                        {
                                            @class = "input-custom",
                                            placeholder = "3001234567"
                                        }
                                        )

                                </div>

                            </div>

                            <!-- PASSWORD -->
                            <div class="col-md-6">

                                <label class="form-label-custom">
                                    Contraseña
                                </label>

                                <div class="input-wrap">

                                    <i class="bi bi-lock input-icon"></i>

                                    @Html.PasswordFor(
                                        m => m.Password,
                                        new
                                        {
                                            @class = "input-custom",
                                            placeholder = "Contraseña segura"
                                        })

                                </div>

                            </div>

                            <!-- LICENCIA -->
                            <div class="col-md-6">

                                <label class="form-label-custom">
                                    Número de licencia
                                </label>

                                <div class="input-wrap">

                                    <i class="bi bi-card-text input-icon"></i>

                                    @Html.TextBoxFor(
                                        m => m.Licencia,
                                        new
                                        {
                                            @class = "input-custom",
                                            placeholder = "LIC-123456"
                                        })

                                </div>

                            </div>

                            <!-- VEHICULO -->
                            <div class="col-md-6">

                                <label class="form-label-custom">
                                    Vehículo
                                </label>

                                <div class="input-wrap">

                                    <i class="bi bi-car-front input-icon"></i>

                                    @Html.TextBoxFor(
                                        m => m.Vehiculo,
                                        new
                                        {
                                            @class = "input-custom",
                                            placeholder = "Mazda 3 - Blanco"
                                        })

                                </div>

                            </div>

                        </div>

                        <button type="submit" class="btn-driver">

                            <i class="bi bi-send-fill me-2"></i>

                            Enviar Solicitud

                        </button>

                        <div class="text-center mt-4">

                            <small style="color:rgba(255,255,255,.45)">
                                Al enviar tu solicitud aceptas el proceso de validación de Kinetix.
                            </small>

                        </div>


                        }


                </div>

            </div>

        </div>

    </div>

</div>
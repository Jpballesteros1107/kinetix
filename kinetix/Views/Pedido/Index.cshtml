@model List<kinetix.Models.Pedido>

@{
    ViewBag.Title = "Gestión de Pedidos";
    Layout = "~/Views/Shared/_LayoutAdmin.cshtml";
}

<style>

    .pedido-wrapper {
        background: #0d0d0d;
        min-height: 100vh;
        padding: 36px 22px;
        font-family: 'Inter', sans-serif;
    }

    /* =========================
       HEADER
    ========================== */

    .pedido-header {
        display: flex;
        justify-content: space-between;
        align-items: center;
        flex-wrap: wrap;
        gap: 18px;
        margin-bottom: 30px;
    }

        .pedido-header h1 {
            color: #fff;
            font-size: 34px;
            font-weight: 900;
            margin-bottom: 6px;
        }

        .pedido-header p {
            color: rgba(255,255,255,0.45);
            margin: 0;
            font-size: 14px;
        }

    .btn-new {
        background: #00c853;
        border: none;
        color: #fff;
        padding: 14px 24px;
        border-radius: 16px;
        font-size: 14px;
        font-weight: 700;
        text-decoration: none;
        transition: 0.2s;
        display: inline-flex;
        align-items: center;
        gap: 10px;
    }

        .btn-new:hover {
            background: #00b248;
            color: #fff;
            text-decoration: none;
            transform: translateY(-2px);
        }

    /* =========================
       STATS
    ========================== */

    .stats-grid {
        display: grid;
        grid-template-columns: repeat(4, 1fr);
        gap: 18px;
        margin-bottom: 28px;
    }

    .stat-card {
        background: #141414;
        border: 1px solid rgba(255,255,255,0.07);
        border-radius: 22px;
        padding: 26px 24px;
        transition: 0.2s;
    }

        .stat-card:hover {
            transform: translateY(-3px);
            border-color: rgba(0,200,83,0.2);
        }

    .stat-top {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-bottom: 20px;
    }

    .stat-icon {
        width: 56px;
        height: 56px;
        border-radius: 18px;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 24px;
    }

    .icon-green {
        background: rgba(0,200,83,0.15);
        color: #00c853;
    }

    .icon-blue {
        background: rgba(59,130,246,0.15);
        color: #60a5fa;
    }

    .icon-yellow {
        background: rgba(245,158,11,0.15);
        color: #fbbf24;
    }

    .icon-red {
        background: rgba(239,68,68,0.15);
        color: #f87171;
    }

    .stat-label {
        color: rgba(255,255,255,0.45);
        font-size: 13px;
        font-weight: 600;
        margin-bottom: 8px;
    }

    .stat-value {
        color: #fff;
        font-size: 34px;
        font-weight: 900;
        line-height: 1;
    }

    /* =========================
       TABLE CARD
    ========================== */

    .table-card {
        background: #141414;
        border: 1px solid rgba(255,255,255,0.07);
        border-radius: 28px;
        overflow: hidden;
    }

    .table-header {
        padding: 28px;
        border-bottom: 1px solid rgba(255,255,255,0.06);
        display: flex;
        justify-content: space-between;
        align-items: center;
        flex-wrap: wrap;
        gap: 16px;
    }

        .table-header h3 {
            color: #fff;
            font-size: 22px;
            font-weight: 800;
            margin: 0;
        }

        .table-header p {
            color: rgba(255,255,255,0.4);
            margin: 4px 0 0;
            font-size: 13px;
        }

    .table-badge {
        background: rgba(0,200,83,0.12);
        border: 1px solid rgba(0,200,83,0.2);
        color: #00c853;
        padding: 10px 18px;
        border-radius: 50px;
        font-size: 12px;
        font-weight: 700;
    }

    /* =========================
       TABLE
    ========================== */

    .custom-table {
        width: 100%;
        border-collapse: collapse;
    }

        .custom-table thead th {
            background: #181818;
            color: rgba(255,255,255,0.35);
            font-size: 11px;
            font-weight: 800;
            text-transform: uppercase;
            letter-spacing: 1px;
            padding: 18px 16px;
            border-bottom: 1px solid rgba(255,255,255,0.06);
            white-space: nowrap;
        }

        .custom-table tbody tr {
            border-bottom: 1px solid rgba(255,255,255,0.04);
            transition: 0.2s;
        }

            .custom-table tbody tr:hover {
                background: rgba(255,255,255,0.02);
            }

        .custom-table tbody td {
            padding: 18px 16px;
            color: rgba(255,255,255,0.75);
            font-size: 13px;
            vertical-align: middle;
        }

    .pedido-id {
        color: #fff;
        font-weight: 800;
    }

    .pedido-user {
        color: #fff;
        font-weight: 700;
    }

    .pedido-value {
        color: #00c853;
        font-weight: 800;
    }

    .pedido-date {
        color: rgba(255,255,255,0.45);
        font-size: 12px;
    }

    /* =========================
       STATUS
    ========================== */

    .status-badge {
        padding: 8px 14px;
        border-radius: 50px;
        font-size: 11px;
        font-weight: 800;
        display: inline-flex;
        align-items: center;
        gap: 6px;
    }

    .status-pendiente {
        background: rgba(245,158,11,0.12);
        color: #fbbf24;
        border: 1px solid rgba(245,158,11,0.2);
    }

    .status-aceptado {
        background: rgba(59,130,246,0.12);
        color: #60a5fa;
        border: 1px solid rgba(59,130,246,0.2);
    }

    .status-camino {
        background: rgba(139,92,246,0.12);
        color: #a78bfa;
        border: 1px solid rgba(139,92,246,0.2);
    }

    .status-finalizado {
        background: rgba(0,200,83,0.12);
        color: #00c853;
        border: 1px solid rgba(0,200,83,0.2);
    }

    .status-cancelado {
        background: rgba(239,68,68,0.12);
        color: #f87171;
        border: 1px solid rgba(239,68,68,0.2);
    }

    /* =========================
       ACTIONS
    ========================== */

    .action-group {
        display: flex;
        flex-wrap: wrap;
        gap: 8px;
    }

    .btn-action {
        border: none;
        border-radius: 12px;
        padding: 9px 14px;
        font-size: 11px;
        font-weight: 700;
        transition: 0.2s;
        color: #fff;
    }

        .btn-action:hover {
            transform: translateY(-2px);
        }

    .btn-aceptar {
        background: #2563eb;
    }

    .btn-camino {
        background: #7c3aed;
    }

    .btn-finalizar {
        background: #00c853;
    }

    .btn-cancelar {
        background: #dc2626;
    }

    .no-actions {
        color: rgba(255,255,255,0.3);
        font-size: 12px;
        font-weight: 600;
    }

    /* =========================
       EMPTY
    ========================== */

    .empty-state {
        padding: 70px 20px;
        text-align: center;
    }

        .empty-state i {
            font-size: 60px;
            color: rgba(255,255,255,0.08);
            margin-bottom: 20px;
            display: block;
        }

        .empty-state h4 {
            color: rgba(255,255,255,0.7);
            margin-bottom: 10px;
            font-weight: 700;
        }

        .empty-state p {
            color: rgba(255,255,255,0.35);
            margin: 0;
        }

    /* =========================
       RESPONSIVE
    ========================== */

    @@media (max-width: 1200px) {

        .stats-grid {
            grid-template-columns: repeat(2, 1fr);
        }
    }

    @@media (max-width: 768px) {

        .stats-grid {
            grid-template-columns: 1fr;
        }

        .pedido-header {
            flex-direction: column;
            align-items: flex-start;
        }

        .pedido-wrapper {
            padding: 24px 14px;
        }
    }
</style>


<div class="pedido-wrapper">

    <!-- HEADER -->
    <div class="pedido-header">

        <div>

            <h1>
                Gestión de Viajes
            </h1>

            <p>
                Administra pedidos, estados y recorridos en tiempo real.
            </p>

        </div>

        <a href="/Pedido/Create"
           class="btn-new">

            <i class="bi bi-plus-circle-fill"></i>

            Nuevo Pedido

        </a>

    </div>


    <!-- STATS -->
    <div class="stats-grid">

        <div class="stat-card">

            <div class="stat-top">

                <div class="stat-icon icon-yellow">

                    <i class="bi bi-clock-history"></i>

                </div>

            </div>

            <div class="stat-label">
                Pedidos Pendientes
            </div>

            <div class="stat-value">
                @Model.Count(x => x.Estado == "Pendiente")
            </div>

        </div>


        <div class="stat-card">

            <div class="stat-top">

                <div class="stat-icon icon-blue">

                    <i class="bi bi-car-front-fill"></i>

                </div>

            </div>

            <div class="stat-label">
                En Camino
            </div>

            <div class="stat-value">
                @Model.Count(x => x.Estado == "En Camino")
            </div>

        </div>


        <div class="stat-card">

            <div class="stat-top">

                <div class="stat-icon icon-green">

                    <i class="bi bi-check-circle-fill"></i>

                </div>

            </div>

            <div class="stat-label">
                Finalizados
            </div>

            <div class="stat-value">
                @Model.Count(x => x.Estado == "Finalizado")
            </div>

        </div>


        <div class="stat-card">

            <div class="stat-top">

                <div class="stat-icon icon-red">

                    <i class="bi bi-x-circle-fill"></i>

                </div>

            </div>

            <div class="stat-label">
                Cancelados
            </div>

            <div class="stat-value">
                @Model.Count(x => x.Estado == "Cancelado")
            </div>

        </div>

    </div>


    <!-- TABLE -->
    <div class="table-card">

        <div class="table-header">

            <div>

                <h3>
                    Lista de Pedidos
                </h3>

                <p>
                    Visualiza y actualiza el estado de cada viaje.
                </p>

            </div>

            <div class="table-badge">

                <i class="bi bi-lightning-charge-fill me-1"></i>

                @Model.Count Pedidos registrados

            </div>

        </div>


        @if (Model != null && Model.Count > 0)
        {
            <div class="table-responsive">

                <table class="custom-table">

                    <thead>

                        <tr>

                            <th>ID</th>
                            <th>Cliente</th>
                            <th>Conductor</th>
                            <th>Origen</th>
                            <th>Destino</th>
                            <th>Estado</th>
                            <th>Valor</th>
                            <th>Fecha</th>
                            <th>Acciones</th>

                        </tr>

                    </thead>

                    <tbody>

                        @foreach (var item in Model)
                        {
                            <tr id="fila-@item.IdPedido">

                                <td class="pedido-id">
                                    #@item.IdPedido
                                </td>

                                <td class="pedido-user">
                                    @item.NombreUsuario
                                </td>

                                <td>
                                    @item.NombreConductor
                                </td>

                                <td>
                                    @item.Origen
                                </td>

                                <td>
                                    @item.Destino
                                </td>

                                <td>

                                    @if (item.Estado == "Pendiente")
                                    {
                                        <span class="status-badge status-pendiente">
                                            <i class="bi bi-clock"></i>
                                            Pendiente
                                        </span>
                                    }

                                    else if (item.Estado == "Aceptado")
                                    {
                                        <span class="status-badge status-aceptado">
                                            <i class="bi bi-check-circle"></i>
                                            Aceptado
                                        </span>
                                    }

                                    else if (item.Estado == "En Camino")
                                    {
                                        <span class="status-badge status-camino">
                                            <i class="bi bi-car-front"></i>
                                            En Camino
                                        </span>
                                    }

                                    else if (item.Estado == "Finalizado")
                                    {
                                        <span class="status-badge status-finalizado">
                                            <i class="bi bi-check2-all"></i>
                                            Finalizado
                                        </span>
                                    }

                                    else if (item.Estado == "Cancelado")
                                    {
                                        <span class="status-badge status-cancelado">
                                            <i class="bi bi-x-circle"></i>
                                            Cancelado
                                        </span>
                                    }

                                </td>

                                <td class="pedido-value">

                                    $@String.Format("{0:N0}", item.Valor)

                                </td>

                                <td class="pedido-date">

                                    @item.Fecha.ToString("dd/MM/yyyy HH:mm")

                                </td>

                                <td>

                                    @if (item.Estado != "Finalizado"
                                     && item.Estado != "Cancelado")
                                    {
                                        <div class="action-group">

                                            <button class="btn-action btn-aceptar estado"
                                                    data-id="@item.IdPedido"
                                                    data-estado="Aceptado">

                                                Aceptar

                                            </button>

                                            <button class="btn-action btn-camino estado"
                                                    data-id="@item.IdPedido"
                                                    data-estado="En Camino">

                                                En Camino

                                            </button>

                                            <button class="btn-action btn-finalizar estado"
                                                    data-id="@item.IdPedido"
                                                    data-estado="Finalizado">

                                                Finalizar

                                            </button>

                                            <button class="btn-action btn-cancelar estado"
                                                    data-id="@item.IdPedido"
                                                    data-estado="Cancelado">

                                                Cancelar

                                            </button>

                                        </div>
                                    }
                                    else
                                    {
                                        <span class="no-actions">

                                            Sin acciones disponibles

                                        </span>
                                    }

                                </td>

                            </tr>
                        }

                    </tbody>

                </table>

            </div>
        }
        else
        {
            <div class="empty-state">

                <i class="bi bi-inbox"></i>

                <h4>
                    No hay pedidos registrados
                </h4>

                <p>
                    Los nuevos viajes aparecerán aquí automáticamente.
                </p>

            </div>
        }

    </div>

</div>


<script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>

@section scripts {

    <script>

        $(".estado").click(function () {

            var boton = $(this);

            var id = boton.data("id");

            var estado = boton.data("estado");

            boton.prop("disabled", true);

            $.ajax({

                url: "/Pedido/CambiarEstado",

                type: "POST",

                data:
                {
                    id: id,
                    estado: estado
                },

                success: function () {

                    location.reload();

                },

                error: function () {

                    alert("Error al actualizar estado");

                    boton.prop("disabled", false);

                }

            });

        });

    </script>

}
@model List<kinetix.Models.Pedido>

@{
    ViewBag.Title = "Mis Pedidos";
    Layout = "~/Views/Shared/_LayoutCliente.cshtml";
}

<style>

    .page-header {
        margin-bottom: 30px;
    }

        .page-header h2 {
            font-weight: 800;
            margin-bottom: 8px;
        }

        .page-header p {
            color: #6b7280;
            margin: 0;
        }

    .pedido-grid {
        display: grid;
        grid-template-columns: repeat(auto-fill,minmax(350px,1fr));
        gap: 24px;
    }

    .pedido-card {
        background: white;
        border-radius: 24px;
        padding: 24px;
        box-shadow: 0 10px 30px rgba(0,0,0,.08);
        border: 1px solid #eef1f5;
        transition: .3s;
    }

        .pedido-card:hover {
            transform: translateY(-5px);
        }

    .pedido-top {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-bottom: 20px;
    }

    .pedido-id {
        font-size: 14px;
        color: #6b7280;
        font-weight: 600;
    }

    .valor {
        font-size: 26px;
        font-weight: 800;
        color: #16a34a;
    }

    .ruta {
        margin: 20px 0;
    }

    .ruta-item {
        display: flex;
        gap: 12px;
        margin-bottom: 15px;
    }

    .ruta-icon {
        width: 35px;
        text-align: center;
        font-size: 18px;
    }

    .origen {
        color: #2563eb;
    }

    .destino {
        color: #dc2626;
    }

    .estado {
        padding: 8px 14px;
        border-radius: 20px;
        font-size: 12px;
        font-weight: 700;
        display: inline-block;
    }

    .pendiente {
        background: #fef3c7;
        color: #92400e;
    }

    .aceptado {
        background: #dbeafe;
        color: #1e40af;
    }

    .camino {
        background: #ede9fe;
        color: #6d28d9;
    }

    .finalizado {
        background: #dcfce7;
        color: #166534;
    }

    .cancelado {
        background: #fee2e2;
        color: #991b1b;
    }

    .fecha {
        margin-top: 18px;
        color: #6b7280;
        font-size: 13px;
    }

    .empty-state {
        text-align: center;
        padding: 80px 20px;
        color: #6b7280;
    }
</style>

<div class="page-header">

    <h2>
        Mis Viajes
    </h2>

    <p>
        Consulta el historial y estado de tus recorridos.
    </p>

</div>

@if (Model != null && Model.Count > 0)
{
    <div class="pedido-grid">

        @foreach (var item in Model)
        {
            <div class="pedido-card">

                <div class="pedido-top">

                    <div class="pedido-id">
                        Pedido #@item.IdPedido
                    </div>

                    <div class="valor">
                        $@String.Format("{0:N0}", item.Valor)
                    </div>

                </div>

                <div class="ruta">

                    <div class="ruta-item">

                        <div class="ruta-icon origen">
                            <i class="bi bi-geo-alt-fill"></i>
                        </div>

                        <div>
                            <strong>Origen</strong><br />
                            @item.Origen
                        </div>

                    </div>

                    <div class="ruta-item">

                        <div class="ruta-icon destino">
                            <i class="bi bi-flag-fill"></i>
                        </div>

                        <div>
                            <strong>Destino</strong><br />
                            @item.Destino
                        </div>

                    </div>

                </div>

                @{
                    string claseEstado = "";

                    switch (item.Estado)
                    {
                        case "Pendiente":
                            claseEstado = "pendiente";
                            break;

                        case "Aceptado":
                            claseEstado = "aceptado";
                            break;

                        case "En Camino":
                            claseEstado = "camino";
                            break;

                        case "Finalizado":
                            claseEstado = "finalizado";
                            break;

                        case "Cancelado":
                            claseEstado = "cancelado";
                            break;
                    }
                }

                <span class="estado @claseEstado">
                    @item.Estado
                </span>

                <div class="fecha">
                    <i class="bi bi-calendar-event"></i>
                    @item.Fecha.ToString("dd/MM/yyyy HH:mm")
                </div>

            </div>
        }

    </div>
}
else
{
    <div class="empty-state">

        <i class="bi bi-car-front"
           style="font-size:70px;"></i>

        <h4 class="mt-3">
            No tienes viajes registrados
        </h4>

        <p>
            Cuando solicites un viaje aparecerá aquí.
        </p>

    </div>
}
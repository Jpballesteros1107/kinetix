
@model List<kinetix.Models.Pedido>

@{
    ViewBag.Title = "Mis Viajes";
    Layout = "~/Views/Shared/_LayoutConductor.cshtml";
}

<style>

    .page-header {
        margin-bottom: 30px;
    }

        .page-header h2 {
            font-weight: 800;
            margin-bottom: 8px;
            color: #111827;
        }

        .page-header p {
            color: #6b7280;
            margin: 0;
        }

    .stats-grid {
        display: grid;
        grid-template-columns: repeat(auto-fit,minmax(220px,1fr));
        gap: 20px;
        margin-bottom: 30px;
    }

    .stat-card {
        background: white;
        border-radius: 20px;
        padding: 20px;
        box-shadow: 0 10px 25px rgba(0,0,0,.06);
        border: 1px solid #eef1f5;
    }

        .stat-card h6 {
            color: #6b7280;
            margin-bottom: 10px;
        }

        .stat-card h3 {
            margin: 0;
            font-weight: 800;
        }

    .viajes-grid {
        display: grid;
        grid-template-columns: repeat(auto-fill,minmax(360px,1fr));
        gap: 24px;
    }

    .viaje-card {
        background: white;
        border-radius: 24px;
        padding: 24px;
        border: 1px solid #e5e7eb;
        box-shadow: 0 12px 32px rgba(0,0,0,.08);
        transition: all .25s ease;
        overflow: hidden;
        position: relative;
    }

        .viaje-card::before {
            content: '';
            position: absolute;
            top: 0;
            left: 0;
            right: 0;
            height: 5px;
            background: linear-gradient(90deg,#2563eb,#16a34a);
        }

        .viaje-card:hover {
            transform: translateY(-6px);
            box-shadow: 0 18px 40px rgba(0,0,0,.12);
        }

    .card-top {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-bottom: 20px;
    }

    .viaje-id {
        font-weight: 800;
        color: #111827;
    }

    .cliente {
        display: flex;
        align-items: center;
        gap: 12px;
        margin-bottom: 20px;
    }

    .cliente-icon {
        width: 52px;
        height: 52px;
        border-radius: 50%;
        background: #dbeafe;
        color: #2563eb;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 22px;
    }

    .ruta {
        margin: 20px 0;
    }

    .ruta-item {
        display: flex;
        gap: 12px;
        align-items: center;
    }

    .ruta-icon {
        width: 32px;
        text-align: center;
        font-size: 18px;
    }

    .origen {
        color: #2563eb;
    }

    .destino {
        color: #dc2626;
    }

    .ruta-linea {
        margin-left: 15px;
        border-left: 2px dashed #d1d5db;
        height: 25px;
        margin-top: 5px;
        margin-bottom: 5px;
    }

    .valor {
        font-size: 34px;
        font-weight: 900;
        color: #16a34a;
        margin-top: 15px;
    }

    .valor-info {
        color: #6b7280;
        font-size: 13px;
        margin-bottom: 15px;
    }

    .fecha {
        color: #6b7280;
        font-size: 13px;
        margin-bottom: 15px;
    }

    .estado {
        display: inline-block;
        padding: 8px 14px;
        border-radius: 20px;
        font-size: 12px;
        font-weight: 700;
        margin-bottom: 15px;
    }

    .estado-pendiente {
        background: #fef3c7;
        color: #92400e;
    }

    .estado-aceptado {
        background: #dbeafe;
        color: #1e40af;
    }

    .estado-finalizado {
        background: #dcfce7;
        color: #166534;
    }

    .estado-cancelado {
        background: #fee2e2;
        color: #991b1b;
    }

    .acciones {
        display: flex;
        gap: 10px;
        margin-top: 10px;
    }

    .btn-driver {
        flex: 1;
        border: none;
        border-radius: 14px;
        padding: 12px;
        font-weight: 700;
        transition: .2s;
        color: white;
    }

    .btn-aceptar {
        background: #16a34a;
    }

    .btn-finalizar {
        background: #2563eb;
    }

    .btn-driver:hover {
        opacity: .9;
    }

    .badge-pago {
        display: inline-block;
        background: #f3f4f6;
        color: #111827;
        padding: 8px 12px;
        border-radius: 999px;
        font-size: 13px;
        margin-bottom: 15px;
    }

    .sin-viajes {
        text-align: center;
        padding: 80px 20px;
        color: #6b7280;
    }
</style>

<div class="page-header">

    <h2>
        Mis Viajes
    </h2>

    <p>
        Administra solicitudes, acepta viajes y realiza seguimiento de tus servicios.
    </p>

</div>

@if (Model != null)
{
    <div class="stats-grid">

        <div class="stat-card">
            <h6>Total Viajes</h6>
            <h3>@Model.Count</h3>
        </div>

        <div class="stat-card">
            <h6>Pendientes</h6>
            <h3>@Model.Count(x => x.Estado == "Pendiente")</h3>
        </div>

        <div class="stat-card">
            <h6>Finalizados</h6>
            <h3>@Model.Count(x => x.Estado == "Finalizado")</h3>
        </div>

    </div>
}

@if (Model != null && Model.Count > 0)
{
    <div class="viajes-grid">

        @foreach (var item in Model)
        {
            <div class="viaje-card">

                <div class="card-top">

                    <span class="viaje-id">
                        Viaje #@item.IdPedido
                    </span>

                </div>

                <div class="cliente">

                    <div class="cliente-icon">
                        <i class="bi bi-person-fill"></i>
                    </div>

                    <div>
                        <strong>@item.NombreUsuario</strong>
                        <small>Cliente</small>
                    </div>

                </div>

                <div class="ruta">

                    <div class="ruta-item">

                        <div class="ruta-icon origen">
                            <i class="bi bi-geo-alt-fill"></i>
                        </div>

                        <div>
                            <small>Origen</small>
                            <div>
                                <strong>@item.Origen</strong>
                            </div>
                        </div>

                    </div>

                    <div class="ruta-linea"></div>

                    <div class="ruta-item">

                        <div class="ruta-icon destino">
                            <i class="bi bi-flag-fill"></i>
                        </div>

                        <div>
                            <small>Destino</small>
                            <div>
                                <strong>@item.Destino</strong>
                            </div>
                        </div>

                    </div>

                </div>

                @if (!string.IsNullOrEmpty(item.MetodoPago))
                {
                    <div class="badge-pago">
                        <i class="bi bi-credit-card"></i>
                        @item.MetodoPago
                    </div>
                }

                <div class="valor">
                    $@String.Format("{0:N0}", item.Valor)
                </div>

                <div class="valor-info">
                   Tarifa del viaje
                </div>

                <div class="fecha">
                    <i class="bi bi-calendar-event"></i>
                    @item.Fecha.ToString("dd/MM/yyyy HH:mm")
                </div>

                @if (item.Estado == "Pendiente")
                {
                    <span class="estado estado-pendiente">
                        Pendiente
                    </span>

                    <div class="acciones">

                        <button class="btn-driver btn-aceptar estado-btn"
                                data-id="@item.IdPedido"
                                data-estado="Aceptado">

                            <i class="bi bi-check-circle"></i>
                            Aceptar

                        </button>

                    </div>
                }
                else if (item.Estado == "Aceptado")
                {
                    <span class="estado estado-aceptado">
                        Viaje aceptado
                    </span>

                    <div class="acciones">

                        <button class="btn-driver btn-finalizar estado-btn"
                                data-id="@item.IdPedido"
                                data-estado="Finalizado">

                            <i class="bi bi-flag-fill"></i>
                            Finalizar Viaje

                        </button>

                    </div>
                }
                else if (item.Estado == "Finalizado")
                {
                    <span class="estado estado-finalizado">
                        Viaje finalizado
                    </span>
                }
                else if (item.Estado == "Cancelado")
                {
                    <span class="estado estado-cancelado">
                        Viaje cancelado
                    </span>
                }

            </div>
        }

    </div>
}
else
{
    <div class="sin-viajes">

        <i class="bi bi-car-front"
           style="font-size:70px;"></i>

        <h4 class="mt-3">
            No hay viajes disponibles
        </h4>

        <p>
            Cuando existan solicitudes aparecerán aquí.
        </p>

    </div>
}

<script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>

<script>

    $(document).on("click", ".estado-btn", function () {

        const id = $(this).data("id");
        const estado = $(this).data("estado");

        if (!confirm("¿Deseas cambiar el estado a " + estado + "?"))
            return;

        const btn = $(this);

        btn.prop("disabled", true);

        btn.html(
            '<i class="bi bi-hourglass-split"></i> Procesando...'
        );

        $.post("/Pedido/CambiarEstado",
            {
                id: id,
                estado: estado
            },
            function () {

                location.reload();

            })
            .fail(function () {

                alert("Ocurrió un error.");

                btn.prop("disabled", false);

            });

    });

</script>


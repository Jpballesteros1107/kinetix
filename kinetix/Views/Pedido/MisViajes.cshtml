@model List<kinetix.Models.Pedido>

@{
    ViewBag.Title = "Mis Viajes";
    Layout = "~/Views/Shared/_LayoutConductor.cshtml";
}

<style>

    .page-header {
        margin-bottom: 30px;
    }

        .page-header h2 {
            font-weight: 800;
            margin-bottom: 8px;
        }

        .page-header p {
            color: #6b7280;
            margin: 0;
        }

    .viajes-grid {
        display: grid;
        grid-template-columns: repeat(auto-fill,minmax(360px,1fr));
        gap: 24px;
    }

    .viaje-card {
        background: #fff;
        border-radius: 24px;
        padding: 24px;
        box-shadow: 0 10px 30px rgba(0,0,0,.08);
        transition: .3s;
        border: 1px solid #eef1f5;
    }

        .viaje-card:hover {
            transform: translateY(-4px);
        }

    .card-top {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-bottom: 18px;
    }

    .viaje-id {
        font-weight: 800;
        color: #111827;
    }

    .cliente {
        display: flex;
        align-items: center;
        gap: 12px;
        margin-bottom: 20px;
    }

    .cliente-icon {
        width: 50px;
        height: 50px;
        border-radius: 50%;
        background: #dbeafe;
        color: #2563eb;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 22px;
    }

    .cliente strong {
        display: block;
    }

    .ruta {
        margin: 20px 0;
    }

    .ruta-item {
        display: flex;
        gap: 12px;
        margin-bottom: 14px;
    }

    .ruta-icon {
        width: 32px;
        text-align: center;
    }

    .origen {
        color: #2563eb;
    }

    .destino {
        color: #dc2626;
    }

    .valor {
        font-size: 28px;
        font-weight: 800;
        color: #16a34a;
        margin-bottom: 10px;
    }

    .fecha {
        color: #6b7280;
        font-size: 13px;
        margin-bottom: 18px;
    }

    .estado {
        display: inline-block;
        padding: 8px 14px;
        border-radius: 20px;
        font-size: 12px;
        font-weight: 700;
        margin-bottom: 18px;
    }

    .estado-pendiente {
        background: #fef3c7;
        color: #92400e;
    }

    .estado-aceptado {
        background: #dbeafe;
        color: #1e40af;
    }

    .estado-finalizado {
        background: #dcfce7;
        color: #166534;
    }

    .estado-cancelado {
        background: #fee2e2;
        color: #991b1b;
    }

    .acciones {
        display: flex;
        gap: 10px;
    }

    .btn-driver {
        flex: 1;
        border: none;
        border-radius: 14px;
        padding: 12px;
        font-weight: 700;
        transition: .2s;
        color: white;
    }

    .btn-aceptar {
        background: #16a34a;
    }

    .btn-finalizar {
        background: #2563eb;
    }

    .btn-driver:hover {
        opacity: .9;
    }

    .sin-viajes {
        text-align: center;
        padding: 80px 20px;
        color: #6b7280;
    }
</style>

<div class="page-header">

    ```
    <h2>
        Mis Viajes
    </h2>

    <p>
        Administra tus solicitudes y genera ingresos.
    </p>
    ```

</div>

@if (Model != null && Model.Count > 0)
{<div class="viajes-grid">

        ```
        @foreach (var item in Model)
        {
            <div class="viaje-card">

                <div class="card-top">

                    <span class="viaje-id">
                        Viaje #@item.IdPedido
                    </span>

                </div>

                <div class="cliente">

                    <div class="cliente-icon">
                        <i class="bi bi-person-fill"></i>
                    </div>

                    <div>
                        <strong>@item.NombreUsuario</strong>
                        <small>Cliente</small>
                    </div>

                </div>

                <div class="ruta">

                    <div class="ruta-item">

                        <div class="ruta-icon origen">
                            <i class="bi bi-geo-alt-fill"></i>
                        </div>

                        <div>
                            <strong>Origen</strong><br />
                            @item.Origen
                        </div>

                    </div>

                    <div class="ruta-item">

                        <div class="ruta-icon destino">
                            <i class="bi bi-flag-fill"></i>
                        </div>

                        <div>
                            <strong>Destino</strong><br />
                            @item.Destino
                        </div>

                    </div>

                </div>

                <div class="valor">
                    $@String.Format("{0:N0}", item.Valor)
                </div>

                <div class="fecha">
                    <i class="bi bi-calendar-event"></i>
                    @item.Fecha.ToString("dd/MM/yyyy HH:mm")
                </div>

                @if (item.Estado == "Pendiente")
                {
                    <span class="estado estado-pendiente">
                        Pendiente
                    </span>

                    <div class="acciones">

                        <button class="btn-driver btn-aceptar estado-btn"
                                data-id="@item.IdPedido"
                                data-estado="Aceptado">

                            <i class="bi bi-check-circle"></i>
                            Aceptar

                        </button>

                    </div>
                }
                else if (item.Estado == "Aceptado")
                {
                    <span class="estado estado-aceptado">
                        Viaje aceptado
                    </span>

                    <div class="acciones">

                        <button class="btn-driver btn-finalizar estado-btn"
                                data-id="@item.IdPedido"
                                data-estado="Finalizado">

                            <i class="bi bi-flag-fill"></i>
                            Finalizar Viaje

                        </button>

                    </div>
                }
                else if (item.Estado == "Finalizado")
                {
                    <span class="estado estado-finalizado">
                        Viaje finalizado
                    </span>
                }
                else if (item.Estado == "Cancelado")
                {
                    <span class="estado estado-cancelado">
                        Viaje cancelado
                    </span>
                }

            </div>
        }

    </div>

}
                else
                { <div class="sin-viajes">

        <i class="bi bi-car-front"
           style="font-size:70px;"></i>

        <h4 class="mt-3">
            No hay viajes disponibles
        </h4>

    </div>

}

<script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>

<script>

    $(".estado-btn").click(function () {

        var id = $(this).data("id");
        var estado = $(this).data("estado");

        $.post("/Pedido/CambiarEstado",
            {
                id: id,
                estado: estado
            },
            function () {

                location.reload();

            });

    });

</script>

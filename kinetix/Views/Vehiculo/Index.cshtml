@model List<kinetix.Models.Vehiculo>

@{
    ViewBag.Title = "Vehículos";
    Layout = "~/Views/Shared/_LayoutAdmin.cshtml";
}

<style>

    .vehiculo-wrapper {
        min-height: 100vh;
        background: #0d0d0d;
        padding: 35px;
    }

    .header {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-bottom: 30px;
    }

        .header h1 {
            color: white;
            font-weight: 900;
        }

        .header p {
            color: #888;
            margin: 0;
        }

    .btn-new {
        background: #00c853;
        color: white;
        padding: 12px 22px;
        border-radius: 14px;
        text-decoration: none;
        font-weight: 700;
    }

        .btn-new:hover {
            color: white;
            background: #00b248;
        }

    .stats-grid {
        display: grid;
        grid-template-columns: repeat(4,1fr);
        gap: 18px;
        margin-bottom: 25px;
    }

    .stat-card {
        background: #141414;
        border-radius: 22px;
        padding: 24px;
        border: 1px solid rgba(255,255,255,.05);
    }

    .stat-title {
        color: #888;
        font-size: 13px;
    }

    .stat-value {
        color: white;
        font-size: 32px;
        font-weight: 900;
    }

    .table-card {
        background: #141414;
        border-radius: 24px;
        overflow: hidden;
        border: 1px solid rgba(255,255,255,.05);
    }

    .table-header {
        padding: 25px;
        border-bottom: 1px solid rgba(255,255,255,.05);
    }

        .table-header h3 {
            color: white;
            margin: 0;
        }

    table {
        width: 100%;
        margin: 0;
    }

    thead {
        background: #1a1a1a;
    }

        thead th {
            color: #888;
            padding: 18px;
            font-size: 12px;
            text-transform: uppercase;
        }

    tbody td {
        color: white;
        padding: 18px;
        border-top: 1px solid rgba(255,255,255,.05);
    }

    tbody tr:hover {
        background: #191919;
    }

    .placa {
        font-weight: 800;
        color: #00c853;
    }

    .btn-edit {
        background: #2563eb;
        color: white;
        padding: 8px 14px;
        border-radius: 10px;
        text-decoration: none;
        font-size: 12px;
        font-weight: 700;
    }

    .btn-delete {
        background: #dc2626;
        color: white;
        padding: 8px 14px;
        border-radius: 10px;
        text-decoration: none;
        font-size: 12px;
        font-weight: 700;
    }
</style>

<div class="vehiculo-wrapper">

    <div class="header">

        <div>

            <h1>
                Gestión de Vehículos
            </h1>

            <p>
                Administra la flota de transporte Kinetix
            </p>

        </div>

        <a href="/Vehiculo/Create"
           class="btn-new">

            <i class="bi bi-plus-circle-fill"></i>
            Nuevo Vehículo

        </a>

    </div>

    <div class="stats-grid">

        <div class="stat-card">
            <div class="stat-title">
                Vehículos Registrados
            </div>
            <div class="stat-value">
                @Model.Count
            </div>
        </div>

        <div class="stat-card">
            <div class="stat-title">
                Marcas
            </div>
            <div class="stat-value">
                @Model.Select(x => x.Marca).Distinct().Count()
            </div>
        </div>

        <div class="stat-card">
            <div class="stat-title">
                Conductores
            </div>
            <div class="stat-value">
                @Model.Select(x => x.NombreConductor).Distinct().Count()
            </div>
        </div>

        <div class="stat-card">
            <div class="stat-title">
                Activos
            </div>
            <div class="stat-value">
                @Model.Count
            </div>
        </div>

    </div>

    <div class="table-card">

        <div class="table-header">

            <h3>
                Lista de Vehículos
            </h3>

        </div>

        <div class="table-responsive">

            <table>

                <thead>

                    <tr>
                        <th>ID</th>
                        <th>Placa</th>
                        <th>Modelo</th>
                        <th>Marca</th>
                        <th>Conductor</th>
                        <th>Acciones</th>
                    </tr>

                </thead>

                <tbody>

                    @foreach (var item in Model)
                    {
                        <tr>

                            <td>#@item.IdVehiculo</td>

                            <td class="placa">
                                @item.Placa
                            </td>

                            <td>
                                @item.Modelo
                            </td>

                            <td>
                                @item.Marca
                            </td>

                            <td>
                                @item.NombreConductor
                            </td>

                            <td>

                                <a href="/Vehiculo/Edit/@item.IdVehiculo"
                                   class="btn-edit">

                                    <i class="bi bi-pencil-fill"></i>
                                    Editar

                                </a>

                                <a href="/Vehiculo/Delete/@item.IdVehiculo"
                                   class="btn-delete">

                                    <i class="bi bi-trash-fill"></i>
                                    Eliminar

                                </a>

                            </td>

                        </tr>
                    }

                </tbody>

            </table>

        </div>

    </div>

</div>
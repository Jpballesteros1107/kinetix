@model List<kinetix.Models.Conductor>

@{
    ViewBag.Title = "Conductores";
    Layout = "~/Views/Shared/_LayoutAdmin.cshtml";
}

<style>

    .conductores-wrapper {
        background: #0d0d0d;
        min-height: 100vh;
        padding: 40px 24px;
        font-family: 'Inter', sans-serif;
    }

    .conductores-header {
        display: flex;
        justify-content: space-between;
        align-items: center;
        flex-wrap: wrap;
        gap: 16px;
        margin-bottom: 30px;
    }

        .conductores-header h1 {
            color: #fff;
            font-size: 32px;
            font-weight: 800;
            margin-bottom: 6px;
        }

        .conductores-header p {
            color: rgba(255,255,255,0.45);
            margin: 0;
            font-size: 14px;
        }

    .btn-new {
        background: #00c853;
        color: #fff;
        border: none;
        border-radius: 14px;
        padding: 14px 22px;
        font-weight: 700;
        text-decoration: none;
        transition: 0.2s;
    }

        .btn-new:hover {
            background: #00b248;
            color: #fff;
            transform: translateY(-2px);
        }

    /* =========================
       TABLE CARD
    ========================== */

    .table-card {
        background: #141414;
        border: 1px solid rgba(255,255,255,0.08);
        border-radius: 24px;
        overflow: hidden;
    }

    .table-top {
        padding: 24px 28px;
        border-bottom: 1px solid rgba(255,255,255,0.06);
        display: flex;
        justify-content: space-between;
        align-items: center;
        flex-wrap: wrap;
        gap: 14px;
    }

    .table-title {
        color: #fff;
        font-size: 18px;
        font-weight: 800;
        margin: 0;
    }

    .count-badge {
        background: rgba(0,200,83,0.12);
        color: #00c853;
        border: 1px solid rgba(0,200,83,0.25);
        padding: 7px 14px;
        border-radius: 50px;
        font-size: 12px;
        font-weight: 700;
    }

    /* =========================
       TABLE
    ========================== */

    .table-responsive {
        overflow-x: auto;
    }

    .custom-table {
        width: 100%;
        border-collapse: collapse;
    }

        .custom-table thead th {
            background: #191919;
            color: rgba(255,255,255,0.4);
            font-size: 11px;
            text-transform: uppercase;
            letter-spacing: 1px;
            padding: 18px;
            border-bottom: 1px solid rgba(255,255,255,0.06);
            white-space: nowrap;
        }

        .custom-table tbody tr {
            border-bottom: 1px solid rgba(255,255,255,0.04);
            transition: 0.2s;
        }

            .custom-table tbody tr:hover {
                background: rgba(255,255,255,0.03);
            }

        .custom-table tbody td {
            padding: 18px;
            color: rgba(255,255,255,0.75);
            font-size: 14px;
            vertical-align: middle;
        }

    .td-name {
        color: #fff !important;
        font-weight: 700;
    }

    .td-id {
        color: rgba(255,255,255,0.35);
        font-family: monospace;
    }

    /* =========================
       STATUS
    ========================== */

    .status {
        padding: 8px 14px;
        border-radius: 50px;
        font-size: 12px;
        font-weight: 700;
        display: inline-flex;
        align-items: center;
        gap: 6px;
    }

    .status-activo {
        background: rgba(0,200,83,0.12);
        color: #00c853;
        border: 1px solid rgba(0,200,83,0.25);
    }

    .status-pendiente {
        background: rgba(245,158,11,0.12);
        color: #fbbf24;
        border: 1px solid rgba(245,158,11,0.25);
    }

    .status-inactivo {
        background: rgba(239,68,68,0.12);
        color: #ef4444;
        border: 1px solid rgba(239,68,68,0.25);
    }

    /* =========================
       ACTIONS
    ========================== */

    .actions {
        display: flex;
        gap: 10px;
        flex-wrap: wrap;
    }

    .btn-action {
        padding: 9px 14px;
        border-radius: 12px;
        font-size: 12px;
        font-weight: 700;
        text-decoration: none;
        transition: 0.2s;
        display: inline-flex;
        align-items: center;
        gap: 6px;
    }

    .btn-edit {
        background: rgba(30,136,229,0.12);
        color: #42a5f5;
        border: 1px solid rgba(30,136,229,0.25);
    }

        .btn-edit:hover {
            background: rgba(30,136,229,0.2);
            color: #42a5f5;
        }

    .btn-delete {
        background: rgba(239,68,68,0.12);
        color: #ef4444;
        border: 1px solid rgba(239,68,68,0.25);
    }

        .btn-delete:hover {
            background: rgba(239,68,68,0.2);
            color: #ef4444;
        }

    .btn-approve {
        background: rgba(0,200,83,0.12);
        color: #00c853;
        border: 1px solid rgba(0,200,83,0.25);
    }

        .btn-approve:hover {
            background: rgba(0,200,83,0.2);
            color: #00c853;
        }

    /* =========================
       EMPTY
    ========================== */

    .empty-state {
        padding: 60px 20px;
        text-align: center;
    }

        .empty-state i {
            font-size: 60px;
            color: rgba(255,255,255,0.08);
            margin-bottom: 18px;
        }

        .empty-state h3 {
            color: #fff;
            font-size: 22px;
            font-weight: 700;
            margin-bottom: 8px;
        }

        .empty-state p {
            color: rgba(255,255,255,0.4);
            margin-bottom: 24px;
        }

    @@media (max-width: 768px) {

        .conductores-wrapper {
            padding: 24px 14px;
        }

        .conductores-header {
            flex-direction: column;
            align-items: flex-start;
        }

        .actions {
            flex-direction: column;
        }
    }
</style>


<div class="conductores-wrapper">

    <!-- HEADER -->
    <div class="conductores-header">

        <div>

            <h1>
                Conductores
            </h1>

            <p>
                Administra los conductores registrados en Kinetix
            </p>

        </div>

        <a href="/Conductor/Create"
           class="btn-new">

            <i class="bi bi-plus-circle-fill me-2"></i>

            Nuevo Conductor

        </a>

    </div>


    <!-- TABLE -->
    <div class="table-card">

        <div class="table-top">

            <h2 class="table-title">

                <i class="bi bi-person-badge-fill me-2"
                   style="color:#00c853;">
                </i>

                Lista de Conductores

            </h2>

            <div class="count-badge">

                @Model.Count Conductores

            </div>

        </div>

        @if (Model != null && Model.Count > 0)
        {
            <div class="table-responsive">

                <table class="custom-table">

                    <thead>

                        <tr>

                            <th>ID</th>
                            <th>Usuario</th>
                            <th>Nombre</th>
                            <th>Licencia</th>
                            <th>Teléfono</th>
                            <th>Estado</th>
                            <th>Registro</th>
                            <th>Acciones</th>

                        </tr>

                    </thead>

                    <tbody>

                        @foreach (var item in Model)
                        {
                            <tr>

                                <td class="td-id">
                                    #@item.IdConductor
                                </td>

                                <td class="td-id">
                                    @item.IdUsuario
                                </td>

                                <td class="td-name">
                                    @item.Nombre
                                </td>

                                <td>
                                    @item.Licencia
                                </td>

                                <td>
                                    @item.Telefono
                                </td>

                                <td>

                                    @if (item.Estado == "Activo")
                                    {
                                        <span class="status status-activo">
                                            <i class="bi bi-check-circle-fill"></i>
                                            Activo
                                        </span>
                                    }
                                    else if (item.Estado == "Pendiente")
                                    {
                                        <span class="status status-pendiente">
                                            <i class="bi bi-clock-fill"></i>
                                            Pendiente
                                        </span>
                                    }
                                    else
                                    {
                                        <span class="status status-inactivo">
                                            <i class="bi bi-x-circle-fill"></i>
                                            @item.Estado
                                        </span>
                                    }

                                </td>

                                <td>
                                    @item.FechaRegistro.ToString("dd/MM/yyyy")
                                </td>

                                <td>

                                    <div class="actions">

                                        <a href="/Conductor/Edit/@item.IdConductor"
                                           class="btn-action btn-edit">

                                            <i class="bi bi-pencil-fill"></i>

                                            Editar

                                        </a>

                                        <a href="/Conductor/Delete/@item.IdConductor"
                                           class="btn-action btn-delete">

                                            <i class="bi bi-trash-fill"></i>

                                            Eliminar

                                        </a>

                                        @if (item.Estado == "Pendiente")
                                        {
                                            <a href="/Conductor/Aprobar/@item.IdConductor"
                                               class="btn-action btn-approve">

                                                <i class="bi bi-check-circle-fill"></i>

                                                Aprobar

                                            </a>
                                        }

                                    </div>

                                </td>

                            </tr>
                        }

                    </tbody>

                </table>

            </div>
        }
        else
        {
            <div class="empty-state">

                <i class="bi bi-person-x-fill"></i>

                <h3>
                    No hay conductores registrados
                </h3>

                <p>
                    Cuando agregues conductores aparecerán aquí.
                </p>

                <a href="/Conductor/Create"
                   class="btn-new">

                    Crear Conductor

                </a>

            </div>
        }

    </div>

</div>
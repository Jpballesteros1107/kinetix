@model kinetix.Models.Conductor

@{
    ViewBag.Title = "Nuevo Conductor";
    Layout = "~/Views/Shared/_LayoutAdmin.cshtml";
}

<style>

    .create-wrapper {
        background: #0d0d0d;
        min-height: 100vh;
        padding: 40px 20px;
        font-family: 'Inter', sans-serif;
    }

    .create-container {
        max-width: 720px;
        margin: auto;
    }

    /* =========================
       HEADER
    ========================== */

    .create-header {
        margin-bottom: 28px;
    }

        .create-header h1 {
            color: #fff;
            font-size: 32px;
            font-weight: 800;
            margin-bottom: 8px;
        }

        .create-header p {
            color: rgba(255,255,255,0.45);
            margin: 0;
            font-size: 14px;
        }

    /* =========================
       CARD
    ========================== */

    .create-card {
        background: #141414;
        border: 1px solid rgba(255,255,255,0.08);
        border-radius: 24px;
        padding: 36px;
        box-shadow: 0 10px 30px rgba(0,0,0,0.25);
    }

    /* =========================
       FORM
    ========================== */

    .form-group-custom {
        margin-bottom: 22px;
    }

    .label-custom {
        display: block;
        color: rgba(255,255,255,0.75);
        font-size: 13px;
        font-weight: 700;
        margin-bottom: 10px;
        letter-spacing: 0.3px;
    }

    .input-wrapper {
        position: relative;
    }

    .input-icon {
        position: absolute;
        left: 16px;
        top: 50%;
        transform: translateY(-50%);
        color: rgba(255,255,255,0.25);
        font-size: 15px;
        pointer-events: none;
    }

    .form-input,
    .form-select-custom {
        width: 100%;
        background: #1c1c1c;
        border: 1px solid rgba(255,255,255,0.08);
        border-radius: 16px;
        padding: 14px 16px 14px 46px;
        color: #fff;
        font-size: 14px;
        outline: none;
        transition: 0.2s;
    }

        .form-input::placeholder {
            color: rgba(255,255,255,0.2);
        }

        .form-input:focus,
        .form-select-custom:focus {
            border-color: #00c853;
            box-shadow: 0 0 0 4px rgba(0,200,83,0.12);
        }

    /* =========================
       PASSWORD TOGGLE
    ========================== */

    .input-toggle {
        position: absolute;
        right: 12px;
        top: 50%;
        transform: translateY(-50%);
        background: transparent;
        border: none;
        color: rgba(255,255,255,0.45);
        font-size: 16px;
        cursor: pointer;
        padding: 6px;
    }

    .password-strength {
        margin-top: 8px;
        font-size: 13px;
        color: rgba(255,255,255,0.6);
    }

    .strength-bar {
        width: 100%;
        height: 8px;
        background: rgba(255,255,255,0.06);
        border-radius: 8px;
        overflow: hidden;
        margin-top: 8px;
    }

    .strength-fill {
        height: 100%;
        width: 0%;
        background: #ff3b30;
        transition: width 0.25s ease, background 0.25s ease;
    }

        .form-select-custom option {
            background: #1c1c1c;
            color: #fff;
        }

    /* =========================
       BUTTONS
    ========================== */

    .actions {
        display: flex;
        gap: 14px;
        margin-top: 32px;
        flex-wrap: wrap;
    }

    .btn-save {
        flex: 1;
        background: #00c853;
        border: none;
        color: white;
        border-radius: 16px;
        padding: 15px;
        font-size: 15px;
        font-weight: 700;
        transition: 0.2s;
    }

        .btn-save:hover {
            background: #00b248;
            transform: translateY(-2px);
        }

    .btn-cancel {
        flex: 1;
        background: transparent;
        border: 1px solid rgba(255,255,255,0.08);
        color: rgba(255,255,255,0.8);
        border-radius: 16px;
        padding: 15px;
        font-size: 15px;
        font-weight: 700;
        text-align: center;
        text-decoration: none;
        transition: 0.2s;
    }

        .btn-cancel:hover {
            background: rgba(255,255,255,0.05);
            color: #fff;
            text-decoration: none;
        }

    /* =========================
       RESPONSIVE
    ========================== */

    @@media (max-width: 576px) {

        .create-card {
            padding: 26px 20px;
        }

        .actions {
            flex-direction: column;
        }

        .btn-save,
        .btn-cancel {
            width: 100%;
        }
    }
</style>


<div class="create-wrapper">

    <div class="create-container">

        <!-- HEADER -->
        <div class="create-header">

            <h1>
                Nuevo Conductor
            </h1>

            <p>
                Registra un nuevo conductor dentro de la plataforma
            </p>

        </div>


        <!-- CARD -->
        <div class="create-card">

            @using (Html.BeginForm())
            {

                <!-- ID USUARIO -->
                <div class="form-group-custom">

                    <label class="label-custom">
                        ID Usuario
                    </label>

                    <div class="input-wrapper">

                        <i class="bi bi-person-vcard-fill input-icon"></i>

                        @Html.TextBoxFor(
                            x => x.IdUsuario,
                            new
                            {
                                @class = "form-input",
                                placeholder = "ID del usuario asociado",
                                type = "number"
                            })

                    </div>

                </div>


                <!-- NOMBRE -->
                <div class="form-group-custom">

                    <label class="label-custom">
                        Nombre Completo
                    </label>

                    <div class="input-wrapper">

                        <i class="bi bi-person-fill input-icon"></i>

                        @Html.TextBoxFor(
                            x => x.Nombre,
                            new
                            {
                                @class = "form-input",
                                placeholder = "Ingresa el nombre completo"
                            })

                    </div>

                </div>


                <!-- LICENCIA -->
                <div class="form-group-custom">

                    <label class="label-custom">
                        Licencia
                    </label>

                    <div class="input-wrapper">

                        <i class="bi bi-card-text input-icon"></i>

                        @Html.TextBoxFor(
                            x => x.Licencia,
                            new
                            {
                                @class = "form-input",
                                placeholder = "Número de licencia"
                            })

                    </div>

                </div>


                <!-- TELEFONO -->
                <div class="form-group-custom">

                    <label class="label-custom">
                        Número Telefónico
                    </label>

                    <div class="input-wrapper">

                        <i class="bi bi-telephone-fill input-icon"></i>

                        @Html.TextBoxFor(
                            x => x.Telefono,
                            new
                            {
                                @class = "form-input",
                                placeholder = "3001234567"
                            })

                    </div>

                </div>


                <!-- ESTADO -->
                <div class="form-group-custom">

                    <label class="label-custom">
                        Estado
                    </label>

                    <div class="input-wrapper">

                        <i class="bi bi-check-circle-fill input-icon"></i>

                        @Html.DropDownListFor(
                            x => x.Estado,
                            new List<SelectListItem>
                            {
                                new SelectListItem
                                {
                                    Text = "Activo",
                                    Value = "Activo"
                                },

                                new SelectListItem
                                {
                                    Text = "Pendiente",
                                    Value = "Pendiente"
                                },

                                new SelectListItem
                                {
                                    Text = "Inactivo",
                                    Value = "Inactivo"
                                }
                            },
                            "Seleccionar estado",
                            new
                            {
                                @class = "form-select-custom"
                            })

                    </div>

                </div>


                <!-- FECHA REGISTRO -->
                <div class="form-group-custom">

                    <label class="label-custom">
                        Fecha de Registro
                    </label>

                    <div class="input-wrapper">

                        <i class="bi bi-calendar-event-fill input-icon"></i>

                        @Html.TextBoxFor(
                            x => x.FechaRegistro,
                            "{0:yyyy-MM-dd}",
                            new
                            {
                                @class = "form-input",
                                type = "date"
                            })

                    </div>

                </div>


                <!-- BUTTONS -->

                <!-- CONTRASEÑA -->
                <div class="form-group-custom">

                    <label class="label-custom">
                        Contraseña
                    </label>

                    <div class="input-wrapper">

                        <i class="bi bi-lock-fill input-icon"></i>

                        <input id="Password" name="Password" class="form-input" placeholder="Escribe una contraseña segura" type="password" />

                        <button type="button" class="input-toggle" id="TogglePassword" aria-label="Mostrar contraseña">
                            <i class="bi bi-eye"></i>
                        </button>

                        <div class="password-strength" id="PasswordStrengthText">&nbsp;</div>

                        <div class="strength-bar" aria-hidden="true">
                            <div class="strength-fill" id="StrengthFill"></div>
                        </div>

                    </div>

                </div>

<script>
    (function(){
        var pwd = document.getElementById('Password');
        var toggle = document.getElementById('TogglePassword');
        var strengthText = document.getElementById('PasswordStrengthText');
        var strengthFill = document.getElementById('StrengthFill');

        function scorePassword(s) {
            var score = 0;
            if (!s) return 0;
            // length
            if (s.length >= 8) score += 2; else if (s.length >= 5) score += 1;
            // variety
            if (/[a-z]/.test(s)) score += 1;
            if (/[A-Z]/.test(s)) score += 1;
            if (/[0-9]/.test(s)) score += 1;
            if (/[^A-Za-z0-9]/.test(s)) score += 1;
            return score; // 0-6
        }

        function updateStrength() {
            var s = pwd.value;
            var score = scorePassword(s);
            var pct = Math.round((score / 6) * 100);
            strengthFill.style.width = pct + '%';
            var color = '#ff3b30';
            var label = 'Muy débil';
            if (score >= 5) { color = '#00c853'; label = 'Muy fuerte'; }
            else if (score >= 4) { color = '#66bb6a'; label = 'Fuerte'; }
            else if (score >= 3) { color = '#ffd54f'; label = 'Media'; }
            else if (score >= 2) { color = '#ffb74d'; label = 'Débil'; }

            strengthFill.style.background = color;
            strengthText.textContent = s ? label : '\u00A0';
        }

        toggle && toggle.addEventListener('click', function(){
            if (pwd.type === 'password') {
                pwd.type = 'text';
                toggle.innerHTML = '<i class="bi bi-eye-slash"></i>';
                toggle.setAttribute('aria-label', 'Ocultar contraseña');
            } else {
                pwd.type = 'password';
                toggle.innerHTML = '<i class="bi bi-eye"></i>';
                toggle.setAttribute('aria-label', 'Mostrar contraseña');
            }
        });

        pwd && pwd.addEventListener('input', updateStrength);

        // init
        updateStrength();
    })();
</script>
                <div class="actions">

                    <button type="submit"
                            class="btn-save">

                        <i class="bi bi-check-circle-fill me-2"></i>

                        Guardar Conductor

                    </button>

                    <a href="/Conductor"
                       class="btn-cancel">

                        <i class="bi bi-arrow-left me-2"></i>

                        Volver

                    </a>

                </div>

            }

        </div>

    </div>

</div>
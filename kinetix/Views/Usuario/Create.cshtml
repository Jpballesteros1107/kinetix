@model kinetix.Models.Usuario

@{
    ViewBag.Title = "Nuevo Usuario";
    Layout = "~/Views/Shared/_LayoutAdmin.cshtml";
}

<style>

    .create-wrapper {
        background: #0d0d0d;
        min-height: 100vh;
        padding: 40px 20px;
        font-family: 'Inter', sans-serif;
    }

    .create-container {
        max-width: 720px;
        margin: auto;
    }

    /* =========================
       HEADER
    ========================== */

    .create-header {
        margin-bottom: 30px;
    }

        .create-header h1 {
            color: #fff;
            font-size: 32px;
            font-weight: 800;
            margin-bottom: 8px;
        }

        .create-header p {
            color: rgba(255,255,255,0.45);
            font-size: 14px;
            margin: 0;
        }

    /* =========================
       CARD
    ========================== */

    .create-card {
        background: #141414;
        border: 1px solid rgba(255,255,255,0.08);
        border-radius: 24px;
        padding: 38px;
        box-shadow: 0 10px 30px rgba(0,0,0,0.3);
    }

    /* =========================
       FORM
    ========================== */

    .form-group-custom {
        margin-bottom: 22px;
    }

    .label-custom {
        display: block;
        color: rgba(255,255,255,0.75);
        font-size: 13px;
        font-weight: 700;
        margin-bottom: 10px;
        letter-spacing: 0.4px;
    }

    .input-wrapper {
        position: relative;
    }

    .input-icon {
        position: absolute;
        left: 16px;
        top: 50%;
        transform: translateY(-50%);
        color: rgba(255,255,255,0.25);
        font-size: 15px;
        pointer-events: none;
    }

    .form-input,
    .form-select-custom {
        width: 100%;
        background: #1c1c1c;
        border: 1px solid rgba(255,255,255,0.08);
        border-radius: 16px;
        padding: 14px 16px 14px 46px;
        color: #fff;
        font-size: 14px;
        outline: none;
        transition: 0.2s;
    }

        .form-input::placeholder {
            color: rgba(255,255,255,0.2);
        }

        .form-input:focus,
        .form-select-custom:focus {
            border-color: #00c853;
            box-shadow: 0 0 0 4px rgba(0,200,83,0.12);
        }

    .form-select-custom {
        appearance: none;
        cursor: pointer;
    }

    .select-arrow {
        position: absolute;
        right: 16px;
        top: 50%;
        transform: translateY(-50%);
        color: rgba(255,255,255,0.4);
        pointer-events: none;
    }

    /* =========================
       PASSWORD
    ========================== */

    .toggle-password {
        position: absolute;
        right: 16px;
        top: 50%;
        transform: translateY(-50%);
        background: none;
        border: none;
        color: rgba(255,255,255,0.3);
        cursor: pointer;
        transition: 0.2s;
        font-size: 16px;
    }

        .toggle-password:hover {
            color: rgba(255,255,255,0.7);
        }

    /* =========================
       BUTTONS
    ========================== */

    .actions {
        display: flex;
        gap: 14px;
        margin-top: 32px;
        flex-wrap: wrap;
    }

    .btn-save {
        flex: 1;
        background: #00c853;
        border: none;
        color: white;
        border-radius: 16px;
        padding: 15px;
        font-size: 15px;
        font-weight: 700;
        transition: 0.2s;
    }

        .btn-save:hover {
            background: #00b248;
            transform: translateY(-2px);
        }

    .btn-cancel {
        flex: 1;
        background: transparent;
        border: 1px solid rgba(255,255,255,0.08);
        color: rgba(255,255,255,0.8);
        border-radius: 16px;
        padding: 15px;
        font-size: 15px;
        font-weight: 700;
        text-align: center;
        text-decoration: none;
        transition: 0.2s;
    }

        .btn-cancel:hover {
            background: rgba(255,255,255,0.05);
            color: #fff;
            text-decoration: none;
        }

    /* =========================
       RESPONSIVE
    ========================== */

    @@media (max-width: 576px) {

        .create-card {
            padding: 24px 20px;
        }

        .actions {
            flex-direction: column;
        }

        .btn-save,
        .btn-cancel {
            width: 100%;
        }
    }
</style>


<div class="create-wrapper">

    <div class="create-container">

        <!-- HEADER -->
        <div class="create-header">

            <h1>
                Crear Usuario
            </h1>

            <p>
                Registra un nuevo usuario dentro de la plataforma
            </p>

        </div>


        <!-- CARD -->
        <div class="create-card">

            @using (Html.BeginForm())
            {

                <!-- NOMBRE -->
                <div class="form-group-custom">

                    <label class="label-custom">
                        Nombre Completo
                    </label>

                    <div class="input-wrapper">

                        <i class="bi bi-person-fill input-icon"></i>

                        @Html.TextBoxFor(
                            x => x.Nombre,
                            new
                            {
                                @class = "form-input",
                                placeholder = "Ingresa el nombre completo"
                            })

                    </div>

                </div>


                <!-- CORREO -->
                <div class="form-group-custom">

                    <label class="label-custom">
                        Correo Electrónico
                    </label>

                    <div class="input-wrapper">

                        <i class="bi bi-envelope-fill input-icon"></i>

                        @Html.TextBoxFor(
                            x => x.Correo,
                            new
                            {
                                @class = "form-input",
                                placeholder = "correo@ejemplo.com"
                            })

                    </div>

                </div>


                <!-- TELEFONO -->
                <div class="form-group-custom">

                    <label class="label-custom">
                        Número Telefónico
                    </label>

                    <div class="input-wrapper">

                        <i class="bi bi-telephone-fill input-icon"></i>

                        @Html.TextBoxFor(
                            x => x.Telefono,
                            new
                            {
                                @class = "form-input",
                                placeholder = "3001234567"
                            })

                    </div>

                </div>


                <!-- PASSWORD -->
                <div class="form-group-custom">

                    <label class="label-custom">
                        Contraseña
                    </label>

                    <div class="input-wrapper">

                        <i class="bi bi-lock-fill input-icon"></i>

                        @Html.PasswordFor(
                            x => x.Password,
                            new
                            {
                                @class = "form-input",
                                placeholder = "Contraseña segura",
                                id = "passwordInput"
                            })

                        <button type="button"
                                class="toggle-password"
                                onclick="togglePassword()">

                            <i class="bi bi-eye"
                               id="eyeIcon">
                            </i>

                        </button>

                    </div>

                </div>


                <!-- ROL -->
                <div class="form-group-custom">

                    <label class="label-custom">
                        Rol del Usuario
                    </label>

                    <div class="input-wrapper">

                        <i class="bi bi-shield-lock-fill input-icon"></i>

                        @Html.DropDownListFor(
                            x => x.Rol,
                            new List<SelectListItem>
                            {
                                new SelectListItem
                                {
                                    Text = "Administrador",
                                    Value = "Admin"
                                },

                                new SelectListItem
                                {
                                    Text = "Cliente",
                                    Value = "Cliente"
                                },

                                new SelectListItem
                                {
                                    Text = "Conductor",
                                    Value = "Conductor"
                                }
                            },
                            "Selecciona un rol",
                            new
                            {
                                @class = "form-select-custom"
                            })

                        <i class="bi bi-chevron-down select-arrow"></i>

                    </div>

                </div>


                <!-- ESTADO -->
                <div class="form-group-custom">

                    <label class="label-custom">
                        Estado
                    </label>

                    <div class="input-wrapper">

                        <i class="bi bi-check-circle-fill input-icon"></i>

                        @Html.DropDownListFor(
                            x => x.Estado,
                            new List<SelectListItem>
                            {
                                new SelectListItem
                                {
                                    Text = "Activo",
                                    Value = "Activo"
                                },

                                new SelectListItem
                                {
                                    Text = "Inactivo",
                                    Value = "Inactivo"
                                }
                            },
                            "Selecciona un estado",
                            new
                            {
                                @class = "form-select-custom"
                            })

                        <i class="bi bi-chevron-down select-arrow"></i>

                    </div>

                </div>


                <!-- BUTTONS -->
                <div class="actions">

                    <button type="submit"
                            class="btn-save">

                        <i class="bi bi-check-circle-fill me-2"></i>

                        Guardar Usuario

                    </button>

                    <a href="/Usuario"
                       class="btn-cancel">

                        <i class="bi bi-arrow-left me-2"></i>

                        Volver

                    </a>

                </div>

            }

        </div>

    </div>

</div>


@section scripts {

    <script>

        function togglePassword() {

            const input =
                document.getElementById('passwordInput');

            const icon =
                document.getElementById('eyeIcon');

            if (input.type === 'password') {

                input.type = 'text';

                icon.className =
                    'bi bi-eye-slash';

            }
            else {

                input.type = 'password';

                icon.className =
                    'bi bi-eye';

            }

        }

    </script>

}
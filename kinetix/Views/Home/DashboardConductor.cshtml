@model List<kinetix.Models.Pedido>

@{
    ViewBag.Title = "Dashboard Conductor";

    Layout =
    "~/Views/Shared/_LayoutConductor.cshtml";
}

<div class="container-fluid">

    <!-- HERO -->
    <div class="hero-driver text-white rounded-4 shadow-lg p-5 mb-5">

        <div class="row align-items-center">

            <div class="col-lg-8">

                <h1 class="display-5 fw-bold mb-3">

                    Hola,
                    @Session["Usuario"] 👋

                </h1>

                <p class="lead mb-4">

                    Administra tus viajes y recibe
                    solicitudes en tiempo real.

                </p>

            </div>

            <div class="col-lg-4 text-center">

                <i class="bi bi-car-front-fill"
                   style="font-size:120px;">
                </i>

            </div>

        </div>

    </div>


    <!-- STATS -->
    <div class="row g-4 mb-5">

        <div class="col-md-4">

            <div class="card shadow-lg rounded-4 p-4">

                <div class="d-flex align-items-center">

                    <div class="icon-box bg-primary text-white me-3">

                        <i class="bi bi-map"></i>

                    </div>

                    <div>

                        <h6 class="text-muted">

                            Viajes Totales

                        </h6>

                        <h2 class="fw-bold">

                            @Model.Count

                        </h2>

                    </div>

                </div>

            </div>

        </div>

        <div class="col-md-4">

            <div class="card shadow-lg rounded-4 p-4">

                <div class="d-flex align-items-center">

                    <div class="icon-box bg-success text-white me-3">

                        <i class="bi bi-cash-stack"></i>

                    </div>

                    <div>

                        <h6 class="text-muted">

                            Ganancias Hoy

                        </h6>

                        <h2 class="fw-bold">

                            $120K

                        </h2>

                    </div>

                </div>

            </div>

        </div>

        <div class="col-md-4">

            <div class="card shadow-lg rounded-4 p-4">

                <div class="d-flex align-items-center">

                    <div class="icon-box bg-dark text-white me-3">

                        <i class="bi bi-star-fill"></i>

                    </div>

                    <div>

                        <h6 class="text-muted">

                            Calificación

                        </h6>

                        <h2 class="fw-bold">

                            4.9

                        </h2>

                    </div>

                </div>

            </div>

        </div>

    </div>


    <!-- VIAJES -->
    <div class="row">

        @if (Model.Count > 0)
        {
            foreach (var item in Model)
            {
                <div class="col-lg-6 mb-4">

                    <div class="card shadow-lg rounded-4 p-4 h-100">

                        <div class="d-flex justify-content-between align-items-center mb-4">

                            <h4 class="fw-bold mb-0">

                                Viaje #@item.IdPedido

                            </h4>

                            @if (item.Estado == "Pendiente")
                            {
                                <span class="status-badge bg-warning text-dark">

                                    Pendiente

                                </span>
                            }

                            @if (item.Estado == "Aceptado")
                            {
                                <span class="status-badge bg-primary text-white">

                                    Aceptado

                                </span>
                            }

                            @if (item.Estado == "En Curso")
                            {
                                <span class="status-badge bg-dark text-white">

                                    En Curso

                                </span>
                            }

                            @if (item.Estado == "Finalizado")
                            {
                                <span class="status-badge bg-success text-white">

                                    Finalizado

                                </span>
                            }

                        </div>

                        <div class="mb-3">

                            <p class="mb-2">

                                <i class="bi bi-geo-alt-fill text-danger me-2"></i>

                                <strong>Origen:</strong>
                                @item.Origen

                            </p>

                            <p class="mb-2">

                                <i class="bi bi-flag-fill text-success me-2"></i>

                                <strong>Destino:</strong>
                                @item.Destino

                            </p>

                            <p class="mb-0">

                                <i class="bi bi-cash text-primary me-2"></i>

                                <strong>Valor:</strong>
                                $@item.Valor

                            </p>

                        </div>

                        <div class="mt-4">

                            @if (item.Estado == "Pendiente")
                            {
                                <form method="post"
                                      action="/Pedido/CambiarEstado">

                                    <input type="hidden"
                                           name="id"
                                           value="@item.IdPedido" />

                                    <input type="hidden"
                                           name="estado"
                                           value="Aceptado" />

                                    <button type="submit"
                                            class="btn btn-success w-100 py-3 rounded-4">

                                        <i class="bi bi-check-circle-fill me-2"></i>

                                        Aceptar Viaje

                                    </button>

                                </form>
                            }

                            @if (item.Estado == "Aceptado")
                            {
                                <form method="post"
                                      action="/Pedido/CambiarEstado">

                                    <input type="hidden"
                                           name="id"
                                           value="@item.IdPedido" />

                                    <input type="hidden"
                                           name="estado"
                                           value="En Curso" />

                                    <button type="submit"
                                            class="btn btn-primary w-100 py-3 rounded-4">

                                        <i class="bi bi-play-fill me-2"></i>

                                        Iniciar Viaje

                                    </button>

                                </form>
                            }

                            @if (item.Estado == "En Curso")
                            {
                                <form method="post"
                                      action="/Pedido/CambiarEstado">

                                    <input type="hidden"
                                           name="id"
                                           value="@item.IdPedido" />

                                    <input type="hidden"
                                           name="estado"
                                           value="Finalizado" />

                                    <button type="submit"
                                            class="btn btn-dark w-100 py-3 rounded-4">

                                        <i class="bi bi-flag-fill me-2"></i>

                                        Finalizar Viaje

                                    </button>

                                </form>
                            }

                        </div>

                    </div>

                </div>
            }
        }
        else
        {
            <div class="col-12">

                <div class="card shadow-lg rounded-4 p-5 text-center">

                    <i class="bi bi-car-front"
                       style="font-size:80px;"></i>

                    <h2 class="fw-bold mt-4">

                        No tienes viajes asignados

                    </h2>

                    <p class="text-muted">

                        Las nuevas solicitudes aparecerán aquí.

                    </p>

                </div>

            </div>
        }

    </div>

</div>
@{
    ViewBag.Title = "Kinetix";
}

<main class="bg-white text-dark">

    <!-- HERO -->
    <section class="bg-black text-white">

        <div class="container py-5">

            <div class="row align-items-center min-vh-100">

                <div class="col-md-6">

                    <h1 class="display-2 fw-bold mb-4">

                        Muévete
                        por la ciudad
                        con Kinetix.

                    </h1>

                    <p class="lead text-light mb-4">

                        Solicita viajes rápidos, seguros y confiables
                        desde cualquier lugar de la ciudad.

                    </p>

                    <p class="mb-5 text-secondary">

                        Una plataforma moderna inspirada en las
                        mejores aplicaciones de movilidad urbana.

                    </p>

                    <a href="/Registro"
                       class="btn btn-success btn-lg px-5 me-3 rounded-pill">

                        Empezar Ahora

                    </a>

                    <a href="/ConductorRegistro"
                       class="btn btn-outline-light btn-lg px-5 rounded-pill">

                        Conducir con Kinetix

                    </a>

                </div>

                <div class="col-md-6 text-center">

                    <img src="https://images.unsplash.com/photo-1519003722824-194d4455a60c?q=80&w=1200"
                         class="img-fluid rounded-4 shadow-lg"
                         style="max-height:600px; object-fit:cover;" />

                </div>

            </div>

        </div>

    </section>


    <!-- COMO FUNCIONA -->
    <section class="py-5 bg-light">

        <div class="container">

            <div class="text-center mb-5">

                <h2 class="fw-bold display-5">

                    ¿Cómo funciona?

                </h2>

                <p class="text-muted">

                    Solicitar un viaje nunca fue tan fácil.

                </p>

            </div>

            <div class="row text-center">

                <div class="col-md-4 mb-4">

                    <div class="p-4">

                        <div class="display-4 mb-3">
                            📍
                        </div>

                        <h3 class="fw-bold">

                            Elige tu destino

                        </h3>

                        <p class="text-muted">

                            Ingresa el punto de recogida
                            y hacia dónde deseas ir.

                        </p>

                    </div>

                </div>

                <div class="col-md-4 mb-4">

                    <div class="p-4">

                        <div class="display-4 mb-3">
                            🚘
                        </div>

                        <h3 class="fw-bold">

                            Encuentra un conductor

                        </h3>

                        <p class="text-muted">

                            Kinetix conecta automáticamente
                            con conductores disponibles.

                        </p>

                    </div>

                </div>

                <div class="col-md-4 mb-4">

                    <div class="p-4">

                        <div class="display-4 mb-3">
                            ⭐
                        </div>

                        <h3 class="fw-bold">

                            Disfruta el viaje

                        </h3>

                        <p class="text-muted">

                            Viajes cómodos,
                            rápidos y seguros.

                        </p>

                    </div>

                </div>

            </div>

        </div>

    </section>


    <!-- BENEFICIOS -->
    <section class="py-5">

        <div class="container">

            <div class="row align-items-center">

                <div class="col-md-6">

                    <img src="https://images.unsplash.com/photo-1494976388531-d1058494cdd8?q=80&w=1200"
                         class="img-fluid rounded-4 shadow" />

                </div>

                <div class="col-md-6">

                    <h2 class="display-5 fw-bold mb-4">

                        Seguridad y confianza
                        en cada trayecto.

                    </h2>

                    <div class="mb-4">

                        <h5 class="fw-bold">
                            ✔ Conductores verificados
                        </h5>

                        <p class="text-muted">

                            Todos los conductores pasan
                            por validaciones y aprobación.

                        </p>

                    </div>

                    <div class="mb-4">

                        <h5 class="fw-bold">
                            ✔ Viajes en tiempo real
                        </h5>

                        <p class="text-muted">

                            Consulta el estado de tu viaje
                            en cualquier momento.

                        </p>

                    </div>

                    <div class="mb-4">

                        <h5 class="fw-bold">
                            ✔ Plataforma moderna
                        </h5>

                        <p class="text-muted">

                            Desarrollada con tecnologías
                            modernas y escalables.

                        </p>

                    </div>

                </div>

            </div>

        </div>

    </section>


    <!-- CONDUCTORES -->
    <section class="bg-dark text-white py-5">

        <div class="container text-center">

            <h2 class="display-5 fw-bold mb-4">

                Genera ingresos
                conduciendo con Kinetix

            </h2>

            <p class="lead text-light mb-5">

                Únete a nuestra red de conductores
                y comienza a generar ganancias.

            </p>

            <a href="/ConductorRegistro"
               class="btn btn-success btn-lg px-5 rounded-pill">

                Registrarme como conductor

            </a>

        </div>

    </section>


    <!-- CTA FINAL -->
    <section class="py-5">

        <div class="container">

            <div class="bg-success text-white rounded-4 p-5 text-center shadow-lg">

                <h2 class="display-5 fw-bold mb-3">

                    ¿Listo para comenzar?

                </h2>

                <p class="lead mb-4">

                    Regístrate y comienza a usar Kinetix hoy mismo.

                </p>

                <a href="/Registro"
                   class="btn btn-light btn-lg px-5 rounded-pill">

                    Crear Cuenta

                </a>

            </div>

        </div>

    </section>

</main>
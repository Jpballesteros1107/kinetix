@{
    ViewBag.Title = "Kinetix";
}

<main>

    <section class="text-center mb-5">

        <h1 class="display-4">
            KINETIX
        </h1>

        <p class="lead">
            Plataforma inteligente de transporte urbano inspirada en servicios tipo Uber.
        </p>

        <p>
            Gestiona usuarios, conductores, vehículos, pedidos y facturas desde una sola plataforma MVC.
        </p>

        <br />

        <a href="/Usuario" class="btn btn-primary btn-lg">
            Gestionar Usuarios
        </a>

        <a href="/Pedido" class="btn btn-success btn-lg">
            Ver Pedidos
        </a>

    </section>


    <div class="row text-center">

        <section class="col-md-3">

            <div class="card p-3 shadow-sm">

                <h2>
                    Usuarios
                </h2>

                <p>
                    Administración completa de clientes registrados en Kinetix.
                </p>

                <a class="btn btn-outline-primary"
                   href="/Usuario">
                    Ir al módulo
                </a>

            </div>

        </section>


        <section class="col-md-3">

            <div class="card p-3 shadow-sm">

                <h2>
                    Conductores
                </h2>

                <p>
                    Gestión de conductores, licencias y datos de contacto.
                </p>

                <a class="btn btn-outline-success"
                   href="/Conductor">
                    Ir al módulo
                </a>

            </div>

        </section>


        <section class="col-md-3">

            <div class="card p-3 shadow-sm">

                <h2>
                    Vehículos
                </h2>

                <p>
                    Registro y control de vehículos asociados a conductores.
                </p>

                <a class="btn btn-outline-dark"
                   href="/Vehiculo">
                    Ir al módulo
                </a>

            </div>

        </section>


        <section class="col-md-3">

            <div class="card p-3 shadow-sm">

                <h2>
                    Facturas
                </h2>

                <p>
                    Consulta y administración de pagos y facturación.
                </p>

                <a class="btn btn-outline-danger"
                   href="/Factura">
                    Ir al módulo
                </a>

            </div>

        </section>

    </div>


    <br />
    <br />

    <section class="row text-center">

        <div class="col-md-12">

            <div class="card p-4 bg-light">

                <h2>
                    Acerca de Kinetix
                </h2>

                <p>
                    Kinetix es una plataforma desarrollada en ASP.NET MVC utilizando arquitectura MVC,
                    SQL Server y ADO.NET para la gestión integral de transporte urbano.
                </p>

                <p>
                    El sistema permite administrar pedidos, usuarios, conductores, vehículos y facturación
                    en tiempo real.
                </p>

            </div>

        </div>

    </section>

</main>
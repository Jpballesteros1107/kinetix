@model kinetix.Models.Dashboard

@{
    ViewBag.Title = "Kinetix";
}

<script src="https://cdn.jsdelivr.net/npm/chart.js"></script>

<div class="container-fluid p-0">

    <!-- HERO -->
    <section class="bg-dark text-white text-center py-5">

        <div class="container">

            <h1 class="display-2 fw-bold mb-3">
                KINETIX
            </h1>

            <p class="lead mb-4">

                La nueva generación del transporte urbano.

            </p>

            <p class="mb-5">

                Solicita viajes, administra conductores
                y controla toda la operación desde una sola plataforma.

            </p>

            <a href="/Registro"
               class="btn btn-success btn-lg px-5 me-3">

                Comenzar

            </a>

            <a href="/Login"
               class="btn btn-outline-light btn-lg px-5">

                Iniciar Sesión

            </a>

        </div>

    </section>


    <!-- STATS -->
    <section class="container mt-5">

        <div class="row text-center">

            <div class="col-md-3 mb-4">

                <div class="card shadow border-0 p-4 rounded-4">

                    <h5 class="text-muted">
                        Usuarios
                    </h5>

                    <h1 class="display-5 fw-bold">
                        @Model.TotalUsuarios
                    </h1>

                </div>

            </div>

            <div class="col-md-3 mb-4">

                <div class="card shadow border-0 p-4 rounded-4">

                    <h5 class="text-muted">
                        Conductores
                    </h5>

                    <h1 class="display-5 fw-bold">
                        @Model.TotalConductores
                    </h1>

                </div>

            </div>

            <div class="col-md-3 mb-4">

                <div class="card shadow border-0 p-4 rounded-4">

                    <h5 class="text-muted">
                        Vehículos
                    </h5>

                    <h1 class="display-5 fw-bold">
                        @Model.TotalVehiculos
                    </h1>

                </div>

            </div>

            <div class="col-md-3 mb-4">

                <div class="card shadow border-0 p-4 rounded-4">

                    <h5 class="text-muted">
                        Viajes
                    </h5>

                    <h1 class="display-5 fw-bold">
                        @Model.TotalPedidos
                    </h1>

                </div>

            </div>

        </div>

    </section>


    <!-- GANANCIAS -->
    <section class="container mt-5">

        <div class="row text-center">

            <div class="col-md-4 mb-4">

                <div class="card bg-success text-white border-0 shadow p-5 rounded-4">

                    <h4>
                        Ganancias
                    </h4>

                    <h1 class="display-5 fw-bold">
                        $@Model.Ganancias
                    </h1>

                </div>

            </div>

            <div class="col-md-4 mb-4">

                <div class="card bg-primary text-white border-0 shadow p-5 rounded-4">

                    <h4>
                        Viajes Finalizados
                    </h4>

                    <h1 class="display-5 fw-bold">
                        @Model.ViajesFinalizados
                    </h1>

                </div>

            </div>

            <div class="col-md-4 mb-4">

                <div class="card bg-danger text-white border-0 shadow p-5 rounded-4">

                    <h4>
                        Cancelados
                    </h4>

                    <h1 class="display-5 fw-bold">
                        @Model.ViajesCancelados
                    </h1>

                </div>

            </div>

        </div>

    </section>


    <!-- MODULOS -->
    <section class="container mt-5">

        <h2 class="text-center mb-5 fw-bold">

            Módulos del Sistema

        </h2>

        <div class="row">

            <div class="col-md-3 mb-4">

                <div class="card shadow border-0 rounded-4 p-4 h-100">

                    <h3>
                        Usuarios
                    </h3>

                    <p class="text-muted">

                        Gestión de clientes registrados.

                    </p>

                    <a href="/Usuario"
                       class="btn btn-outline-dark mt-auto">

                        Administrar

                    </a>

                </div>

            </div>

            <div class="col-md-3 mb-4">

                <div class="card shadow border-0 rounded-4 p-4 h-100">

                    <h3>
                        Conductores
                    </h3>

                    <p class="text-muted">

                        Control de conductores y licencias.

                    </p>

                    <a href="/Conductor"
                       class="btn btn-outline-dark mt-auto">

                        Administrar

                    </a>

                </div>

            </div>

            <div class="col-md-3 mb-4">

                <div class="card shadow border-0 rounded-4 p-4 h-100">

                    <h3>
                        Vehículos
                    </h3>

                    <p class="text-muted">

                        Gestión completa de vehículos.

                    </p>

                    <a href="/Vehiculo"
                       class="btn btn-outline-dark mt-auto">

                        Administrar

                    </a>

                </div>

            </div>

            <div class="col-md-3 mb-4">

                <div class="card shadow border-0 rounded-4 p-4 h-100">

                    <h3>
                        Facturación
                    </h3>

                    <p class="text-muted">

                        Consulta y control de pagos.

                    </p>

                    <a href="/Factura"
                       class="btn btn-outline-dark mt-auto">

                        Administrar

                    </a>

                </div>

            </div>

        </div>

    </section>


    <!-- GRAFICA -->
    <section class="container mt-5 mb-5">

        <div class="card shadow border-0 rounded-4 p-5">

            <h2 class="mb-4 text-center">

                Estadísticas Generales

            </h2>

            <canvas id="grafica"></canvas>

        </div>

    </section>

</div>


<script>

var ctx =
    document.getElementById('grafica');

new Chart(ctx,
{
    type: 'bar',

    data:
    {
        labels:
        [
            'Usuarios',
            'Conductores',
            'Vehículos',
            'Pedidos',
            'Facturas'
        ],

        datasets:
        [{
            label: 'Kinetix',

            data:
            [
                @Model.TotalUsuarios,
                @Model.TotalConductores,
                @Model.TotalVehiculos,
                @Model.TotalPedidos,
                @Model.TotalFacturas
            ],

            borderWidth: 1
        }]
    },

    options:
    {
        responsive: true
    }
});

</script>
```

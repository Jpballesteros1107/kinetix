@model kinetix.Models.Dashboard

@{
    ViewBag.Title = "Dashboard Admin";
}

<div class="container-fluid py-4">

    <!-- HEADER -->
    <div class="d-flex justify-content-between align-items-center mb-5">

        <div>

            <h1 class="fw-bold mb-1">

                Dashboard Administrativo

            </h1>

            <p class="text-muted mb-0">

                Bienvenido @Session["Usuario"]

            </p>

        </div>

        <a href="/Login/Logout"
           class="btn btn-dark">

            Cerrar Sesión

        </a>

    </div>


    <!-- CARDS -->
    <div class="row g-4 mb-5">

        <div class="col-md-3">

            <div class="card border-0 shadow-lg rounded-4 p-4">

                <h6 class="text-muted">

                    Usuarios

                </h6>

                <h1 class="fw-bold">

                    @Model.TotalUsuarios

                </h1>

            </div>

        </div>

        <div class="col-md-3">

            <div class="card border-0 shadow-lg rounded-4 p-4">

                <h6 class="text-muted">

                    Conductores

                </h6>

                <h1 class="fw-bold">

                    @Model.TotalConductores

                </h1>

            </div>

        </div>

        <div class="col-md-3">

            <div class="card border-0 shadow-lg rounded-4 p-4">

                <h6 class="text-muted">

                    Vehículos

                </h6>

                <h1 class="fw-bold">

                    @Model.TotalVehiculos

                </h1>

            </div>

        </div>

        <div class="col-md-3">

            <div class="card border-0 shadow-lg rounded-4 p-4">

                <h6 class="text-muted">

                    Viajes

                </h6>

                <h1 class="fw-bold">

                    @Model.TotalPedidos

                </h1>

            </div>

        </div>

    </div>


    <!-- RESUMEN -->
    <div class="row g-4 mb-5">

        <div class="col-md-4">

            <div class="card bg-success text-white border-0 shadow-lg rounded-4 p-4">

                <h5>

                    Ganancias Totales

                </h5>

                <h1 class="fw-bold">

                    $@Model.Ganancias

                </h1>

            </div>

        </div>

        <div class="col-md-4">

            <div class="card bg-primary text-white border-0 shadow-lg rounded-4 p-4">

                <h5>

                    Viajes Finalizados

                </h5>

                <h1 class="fw-bold">

                    @Model.ViajesFinalizados

                </h1>

            </div>

        </div>

        <div class="col-md-4">

            <div class="card bg-danger text-white border-0 shadow-lg rounded-4 p-4">

                <h5>

                    Viajes Cancelados

                </h5>

                <h1 class="fw-bold">

                    @Model.ViajesCancelados

                </h1>

            </div>

        </div>

    </div>


    <!-- SOLICITUDES -->
    <div class="card border-0 shadow-lg rounded-4 p-4 mb-5">

        <div class="d-flex justify-content-between align-items-center mb-4">

            <h3 class="fw-bold mb-0">

                Solicitudes de Conductores

            </h3>

            <span class="badge bg-dark fs-6">

                @Model.Solicitudes.Count Pendientes

            </span>

        </div>

        @if (Model.Solicitudes.Count > 0)
        {
            <div class="table-responsive">

                <table class="table align-middle">

                    <thead>

                        <tr>

                            <th>Nombre</th>

                            <th>Correo</th>

                            <th>Teléfono</th>

                            <th>Licencia</th>

                            <th>Vehículo</th>

                            <th>Acción</th>

                        </tr>

                    </thead>

                    <tbody>

                        @foreach (var item in Model.Solicitudes)
                        {
                            <tr>

                                <td>@item.Nombre</td>

                                <td>@item.Correo</td>

                                <td>@item.Telefono</td>

                                <td>@item.Licencia</td>

                                <td>@item.Vehiculo</td>

                                <td class="d-flex gap-2">

                                    <a href="/Conductor/Aprobar/@item.IdSolicitud"
                                       class="btn btn-success btn-sm rounded-pill">

                                        Aprobar

                                    </a>

                                    <a href="/Conductor/Rechazar/@item.IdSolicitud"
                                       class="btn btn-danger btn-sm rounded-pill">

                                        Rechazar

                                    </a>

                                </td>

                            </tr>
                        }

                    </tbody>

                </table>

            </div>
        }
        else
        {
            <div class="alert alert-light border text-center">

                No hay solicitudes pendientes.

            </div>
        }

    </div>


    <!-- ACCESOS -->
    <div class="row g-3">

        <div class="col-md-3">

            <a href="/Usuario"
               class="btn btn-dark w-100 py-3 rounded-4">

                Usuarios

            </a>

        </div>

        <div class="col-md-3">

            <a href="/Conductor"
               class="btn btn-success w-100 py-3 rounded-4">

                Conductores

            </a>

        </div>

        <div class="col-md-3">

            <a href="/Vehiculo"
               class="btn btn-primary w-100 py-3 rounded-4">

                Vehículos

            </a>

        </div>

        <div class="col-md-3">

            <a href="/Pedido"
               class="btn btn-warning w-100 py-3 rounded-4">

                Pedidos

            </a>

        </div>

    </div>

</div>
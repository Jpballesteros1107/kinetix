@model kinetix.Models.Dashboard

@{
    ViewBag.Title = "Dashboard Admin";

    Layout =
    "~/Views/Shared/_LayoutAdmin.cshtml";
}

<div class="container-fluid py-4">

    <!-- HERO -->
    <div class="hero-gradient text-white rounded-4 shadow-lg p-5 mb-5">

        <div class="d-flex justify-content-between align-items-center flex-wrap">

            <div>

                <h1 class="display-5 fw-bold mb-2">

                    Dashboard Administrativo

                </h1>

                <p class="fs-5 mb-0">

                    Bienvenido,
                    @Session["Usuario"]

                </p>

            </div>

            <div class="mt-3 mt-md-0">

                <span class="badge bg-light text-dark fs-6 px-4 py-3">

                    <i class="bi bi-shield-check me-2"></i>

                    Administrador

                </span>

            </div>

        </div>

    </div>


    <!-- ESTADISTICAS -->
    <div class="row g-4 mb-5">

        <!-- USUARIOS -->
        <div class="col-md-3">

            <div class="card shadow-lg rounded-4 p-4 h-100">

                <div class="d-flex justify-content-between align-items-center">

                    <div>

                        <h6 class="text-muted">

                            Usuarios

                        </h6>

                        <h1 class="fw-bold dashboard-title">

                            @Model.TotalUsuarios

                        </h1>

                    </div>

                    <div class="icon-box bg-primary text-white">

                        <i class="bi bi-people-fill"></i>

                    </div>

                </div>

            </div>

        </div>


        <!-- CONDUCTORES -->
        <div class="col-md-3">

            <div class="card shadow-lg rounded-4 p-4 h-100">

                <div class="d-flex justify-content-between align-items-center">

                    <div>

                        <h6 class="text-muted">

                            Conductores

                        </h6>

                        <h1 class="fw-bold dashboard-title">

                            @Model.TotalConductores

                        </h1>

                    </div>

                    <div class="icon-box bg-success text-white">

                        <i class="bi bi-person-badge-fill"></i>

                    </div>

                </div>

            </div>

        </div>


        <!-- VEHICULOS -->
        <div class="col-md-3">

            <div class="card shadow-lg rounded-4 p-4 h-100">

                <div class="d-flex justify-content-between align-items-center">

                    <div>

                        <h6 class="text-muted">

                            Vehículos

                        </h6>

                        <h1 class="fw-bold dashboard-title">

                            @Model.TotalVehiculos

                        </h1>

                    </div>

                    <div class="icon-box bg-warning text-white">

                        <i class="bi bi-car-front-fill"></i>

                    </div>

                </div>

            </div>

        </div>


        <!-- VIAJES -->
        <div class="col-md-3">

            <div class="card shadow-lg rounded-4 p-4 h-100">

                <div class="d-flex justify-content-between align-items-center">

                    <div>

                        <h6 class="text-muted">

                            Viajes

                        </h6>

                        <h1 class="fw-bold dashboard-title">

                            @Model.TotalPedidos

                        </h1>

                    </div>

                    <div class="icon-box bg-dark text-white">

                        <i class="bi bi-geo-alt-fill"></i>

                    </div>

                </div>

            </div>

        </div>

    </div>


    <!-- RESUMEN -->
    <div class="row g-4 mb-5">

        <div class="col-md-4">

            <div class="card bg-success text-white shadow-lg rounded-4 p-4 h-100">

                <div class="d-flex justify-content-between align-items-center">

                    <div>

                        <h5>

                            Ganancias Totales

                        </h5>

                        <h1 class="fw-bold">

                            $@Model.Ganancias

                        </h1>

                    </div>

                    <i class="bi bi-cash-stack"
                       style="font-size:50px;">
                    </i>

                </div>

            </div>

        </div>

        <div class="col-md-4">

            <div class="card bg-primary text-white shadow-lg rounded-4 p-4 h-100">

                <div class="d-flex justify-content-between align-items-center">

                    <div>

                        <h5>

                            Viajes Finalizados

                        </h5>

                        <h1 class="fw-bold">

                            @Model.ViajesFinalizados

                        </h1>

                    </div>

                    <i class="bi bi-check-circle-fill"
                       style="font-size:50px;">
                    </i>

                </div>

            </div>

        </div>

        <div class="col-md-4">

            <div class="card bg-danger text-white shadow-lg rounded-4 p-4 h-100">

                <div class="d-flex justify-content-between align-items-center">

                    <div>

                        <h5>

                            Viajes Cancelados

                        </h5>

                        <h1 class="fw-bold">

                            @Model.ViajesCancelados

                        </h1>

                    </div>

                    <i class="bi bi-x-circle-fill"
                       style="font-size:50px;">
                    </i>

                </div>

            </div>

        </div>

    </div>


    <!-- SOLICITUDES -->
    <div class="card shadow-lg rounded-4 p-4 mb-5">

        <div class="d-flex justify-content-between align-items-center mb-4 flex-wrap">

            <h3 class="fw-bold mb-3 mb-md-0">

                Solicitudes de Conductores

            </h3>

            <span class="badge bg-dark fs-6">

                @Model.Solicitudes.Count Pendientes

            </span>

        </div>

        @if (Model.Solicitudes != null &&
             Model.Solicitudes.Count > 0)
        {
            <div class="table-responsive">

                <table class="table align-middle">

                    <thead>

                        <tr>

                            <th>Nombre</th>
                            <th>Correo</th>
                            <th>Teléfono</th>
                            <th>Licencia</th>
                            <th>Vehículo</th>
                            <th>Acción</th>

                        </tr>

                    </thead>

                    <tbody>

                        @foreach (var item in Model.Solicitudes)
                        {
                            <tr>

                                <td>@item.Nombre</td>

                                <td>@item.Correo</td>

                                <td>@item.Telefono</td>

                                <td>@item.Licencia</td>

                                <td>@item.Vehiculo</td>

                                <td>

                                    <div class="d-flex gap-2">

                                        <a href="/Conductor/Aprobar/@item.IdSolicitud"
                                           class="btn btn-success btn-sm rounded-pill px-3">

                                            Aprobar

                                        </a>

                                        <a href="/Conductor/Rechazar/@item.IdSolicitud"
                                           class="btn btn-danger btn-sm rounded-pill px-3">

                                            Rechazar

                                        </a>

                                    </div>

                                </td>

                            </tr>
                        }

                    </tbody>

                </table>

            </div>
        }
        else
        {
            <div class="alert alert-light border rounded-4 text-center">

                No hay solicitudes pendientes.

            </div>
        }

    </div>


    <!-- ACCESOS RAPIDOS -->
    <div class="row g-4">

        <div class="col-md-3">

            <a href="/Usuario"
               class="btn btn-dark w-100 py-4 rounded-4">

                <i class="bi bi-people-fill me-2"></i>

                Usuarios

            </a>

        </div>

        <div class="col-md-3">

            <a href="/Conductor"
               class="btn btn-success w-100 py-4 rounded-4">

                <i class="bi bi-person-badge-fill me-2"></i>

                Conductores

            </a>

        </div>

        <div class="col-md-3">

            <a href="/Vehiculo"
               class="btn btn-primary w-100 py-4 rounded-4">

                <i class="bi bi-car-front-fill me-2"></i>

                Vehículos

            </a>

        </div>

        <div class="col-md-3">

            <a href="/Pedido"
               class="btn btn-warning w-100 py-4 rounded-4 text-dark fw-bold">

                <i class="bi bi-geo-alt-fill me-2"></i>

                Pedidos

            </a>

        </div>

    </div>

</div>
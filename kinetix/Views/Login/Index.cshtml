@{
    ViewBag.Title = "Iniciar Sesión";
}

<style>

    body {
        background: radial-gradient(circle at top, rgba(0,200,83,0.12), transparent 35%), #0b0b0b;
        overflow-x: hidden;
    }

    .login-page {
        min-height: 100vh;
        display: flex;
        align-items: center;
        justify-content: center;
        padding: 40px 20px;
        position: relative;
    }

    .login-glow {
        position: absolute;
        width: 500px;
        height: 500px;
        background: #00c853;
        filter: blur(180px);
        opacity: 0.08;
        border-radius: 50%;
        top: -120px;
        right: -120px;
    }

    .login-container {
        width: 100%;
        max-width: 1150px;
        border-radius: 32px;
        overflow: hidden;
        background: #141414;
        border: 1px solid rgba(255,255,255,0.06);
        box-shadow: 0 30px 80px rgba(0,0,0,0.45);
        position: relative;
        z-index: 2;
    }

    .login-left {
        background: linear-gradient( 135deg, #000000, #111111, #1a1a1a );
        color: white;
        padding: 70px;
        height: 100%;
        position: relative;
        overflow: hidden;
    }

        .login-left::before {
            content: '';
            position: absolute;
            width: 420px;
            height: 420px;
            background: rgba(0,200,83,0.08);
            border-radius: 50%;
            bottom: -150px;
            right: -100px;
        }

    .brand {
        display: flex;
        align-items: center;
        gap: 12px;
        margin-bottom: 70px;
        position: relative;
        z-index: 2;
    }

    .brand-icon {
        width: 42px;
        height: 42px;
        border-radius: 14px;
        background: #00c853;
        display: flex;
        align-items: center;
        justify-content: center;
        font-weight: 900;
        font-size: 18px;
    }

    .brand-name {
        font-size: 24px;
        font-weight: 800;
        letter-spacing: 1px;
    }

    .hero-title {
        font-size: 58px;
        font-weight: 900;
        line-height: 1.05;
        margin-bottom: 25px;
        position: relative;
        z-index: 2;
    }

    .hero-text {
        color: rgba(255,255,255,0.7);
        font-size: 18px;
        line-height: 1.8;
        max-width: 520px;
        position: relative;
        z-index: 2;
    }

    .hero-features {
        margin-top: 45px;
        position: relative;
        z-index: 2;
    }

    .feature-item {
        display: flex;
        align-items: center;
        margin-bottom: 20px;
        color: rgba(255,255,255,0.85);
        font-weight: 500;
    }

        .feature-item i {
            color: #00c853;
            margin-right: 14px;
            font-size: 20px;
        }

    .hero-car {
        position: absolute;
        right: 40px;
        bottom: 30px;
        font-size: 130px;
        color: rgba(255,255,255,0.05);
    }

    .login-right {
        background: #141414;
        padding: 70px 60px;
        color: white;
    }

    .login-title {
        font-size: 38px;
        font-weight: 800;
        margin-bottom: 10px;
    }

    .login-subtitle {
        color: rgba(255,255,255,0.45);
        margin-bottom: 40px;
        font-size: 15px;
    }

    .form-label-custom {
        font-size: 14px;
        font-weight: 600;
        color: rgba(255,255,255,0.8);
        margin-bottom: 10px;
        display: block;
    }

    .input-wrap {
        position: relative;
        margin-bottom: 24px;
    }

    .input-icon {
        position: absolute;
        left: 18px;
        top: 50%;
        transform: translateY(-50%);
        color: rgba(255,255,255,0.3);
        font-size: 16px;
    }

    .input-custom {
        width: 100%;
        height: 58px;
        border-radius: 16px;
        border: 1px solid rgba(255,255,255,0.08);
        background: #1d1d1d;
        padding-left: 50px;
        padding-right: 50px;
        color: white;
        font-size: 15px;
        transition: 0.25s;
        outline: none;
    }

        .input-custom::placeholder {
            color: rgba(255,255,255,0.22);
        }

        .input-custom:focus {
            border-color: #00c853;
            box-shadow: 0 0 0 4px rgba(0,200,83,0.12);
        }

    .toggle-password {
        position: absolute;
        right: 18px;
        top: 50%;
        transform: translateY(-50%);
        background: none;
        border: none;
        color: rgba(255,255,255,0.35);
        font-size: 17px;
        cursor: pointer;
    }

        .toggle-password:hover {
            color: rgba(255,255,255,0.75);
        }

    .btn-login {
        width: 100%;
        height: 58px;
        border: none;
        border-radius: 16px;
        background: #00c853;
        color: white;
        font-size: 16px;
        font-weight: 700;
        transition: 0.25s;
        margin-top: 10px;
    }

        .btn-login:hover {
            background: #00b248;
            transform: translateY(-2px);
        }

    .alert-custom {
        background: rgba(220,53,69,0.12);
        border: 1px solid rgba(220,53,69,0.3);
        border-radius: 14px;
        color: #ff7b7b;
        padding: 14px 18px;
        margin-bottom: 28px;
        font-size: 14px;
    }

    .login-footer {
        text-align: center;
        margin-top: 35px;
        color: rgba(255,255,255,0.45);
        font-size: 14px;
    }

        .login-footer a {
            color: #00c853;
            text-decoration: none;
            font-weight: 600;
        }

            .login-footer a:hover {
                text-decoration: underline;
            }

    @@media(max-width:991px) {

        .login-left {
            display: none;
        }

        .login-right {
            padding: 45px 30px;
        }

        .login-title {
            font-size: 30px;
        }
    }
</style>


<div class="login-page">

    <div class="login-glow"></div>

    <div class="login-container">

        <div class="row g-0">

            <!-- LEFT -->
            <div class="col-lg-6">

                <div class="login-left">

                    <div class="brand">

                        <div class="brand-icon">
                            K
                        </div>

                        <div class="brand-name">
                            KINETIX
                        </div>

                    </div>

                    <h1 class="hero-title">

                        Muévete
                        inteligente
                        con Kinetix.

                    </h1>

                    <p class="hero-text">

                        Viajes rápidos, seguros y modernos.
                        Conecta con conductores verificados
                        y disfruta una experiencia premium.

                    </p>

                    <div class="hero-features">

                        <div class="feature-item">

                            <i class="bi bi-check-circle-fill"></i>

                            Conductores verificados

                        </div>

                        <div class="feature-item">

                            <i class="bi bi-check-circle-fill"></i>

                            Viajes monitoreados en tiempo real

                        </div>

                        <div class="feature-item">

                            <i class="bi bi-check-circle-fill"></i>

                            Plataforma moderna y segura

                        </div>

                    </div>

                    <i class="bi bi-car-front-fill hero-car"></i>

                </div>

            </div>


            <!-- RIGHT -->
            <div class="col-lg-6">

                <div class="login-right">

                    <h2 class="login-title">

                        Bienvenido 👋

                    </h2>

                    <p class="login-subtitle">

                        Inicia sesión para continuar en Kinetix.

                    </p>

                    @if (ViewBag.Error != null)
                    {
                        <div class="alert-custom">

                            <i class="bi bi-exclamation-circle me-2"></i>

                            @ViewBag.Error

                        </div>
                    }

                    <form method="post">

                        <label class="form-label-custom">

                            Correo electrónico

                        </label>

                        <div class="input-wrap">

                            <i class="bi bi-envelope input-icon"></i>

                            <input type="email"
                                   name="correo"
                                   class="input-custom"
                                   placeholder="correo@ejemplo.com"
                                   required />

                        </div>


                        <label class="form-label-custom">

                            Contraseña

                        </label>

                        <div class="input-wrap">

                            <i class="bi bi-lock input-icon"></i>

                            <input type="password"
                                   id="passwordInput"
                                   name="password"
                                   class="input-custom"
                                   placeholder="••••••••"
                                   required />

                            <button type="button"
                                    class="toggle-password"
                                    onclick="togglePassword()">

                                <i class="bi bi-eye"
                                   id="eyeIcon">
                                </i>

                            </button>

                        </div>

                        <button type="submit"
                                class="btn-login">

                            Iniciar Sesión

                        </button>

                    </form>

                    <div class="login-footer">

                        ¿No tienes cuenta?

                        <a href="/Registro">

                            Crear cuenta

                        </a>

                        <br /><br />

                        <a href="/ConductorRegistro">

                            Conducir con Kinetix

                        </a>

                    </div>

                </div>

            </div>

        </div>

    </div>

</div>


@section scripts {

    <script>

        function togglePassword() {

            const input =
                document.getElementById(
                    'passwordInput');

            const icon =
                document.getElementById(
                    'eyeIcon');

            if (input.type === 'password') {

                input.type = 'text';

                icon.className =
                    'bi bi-eye-slash';

            }
            else {

                input.type = 'password';

                icon.className =
                    'bi bi-eye';

            }
        }

    </script>

}